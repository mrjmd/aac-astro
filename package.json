    "report:benchmark": "node scripts/seasonal-benchmark.js",
    "report:health": "node scripts/analytics-health-check.js",
    "report:journeys": "node scripts/conversion-journeys.js",
    "audit:cannibalization": "node scripts/cannibalization-audit.js",
    "report:weekly": "node scripts/weekly-report.js",
    "report:monthly": "node scripts/monthly-report.js"
