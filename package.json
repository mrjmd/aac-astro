{
  "name": "attack-a-crack",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev --port=3000 --host=0.0.0.0",
    "build": "astro build",
    "preview": "astro preview",
    "clean": "rm -rf dist",
    "lint": "astro check",
    "validate:schema": "node scripts/validate-schema.js",
    "check:images": "node scripts/check-images.js",
    "check:seo": "node scripts/check-seo.js",
    "check:a11y": "node scripts/check-a11y.js",
    "validate:links": "node scripts/validate-links.js",
    "validate:uniqueness": "node scripts/validate-uniqueness.js",
    "validate": "npm run build && npm run validate:schema && npm run check:images && npm run check:seo && npm run check:a11y && npm run validate:links && npm run validate:uniqueness",
    "screenshot": "node scripts/screenshot.js"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "@tailwindcss/vite": "^4.2.1",
    "@vercel/speed-insights": "^1.3.1",
    "astro": "^5.18.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@lhci/cli": "^0.13.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.14.0",
    "axe-core": "^4.9.0",
    "jsdom": "^24.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "yaml": "^2.4.0"
  }
}
