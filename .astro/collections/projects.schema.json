{
  "$ref": "#/definitions/projects",
  "definitions": {
    "projects": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "metaTitle": {
          "type": "string",
          "minLength": 30,
          "maxLength": 60
        },
        "metaDescription": {
          "type": "string",
          "minLength": 120,
          "maxLength": 160
        },
        "date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "city": {
          "type": "string"
        },
        "state": {
          "type": "string",
          "enum": [
            "CT",
            "MA",
            "RI",
            "NH",
            "ME"
          ]
        },
        "coordinates": {
          "type": "object",
          "properties": {
            "lat": {
              "type": "number"
            },
            "lng": {
              "type": "number"
            }
          },
          "required": [
            "lat",
            "lng"
          ],
          "additionalProperties": false
        },
        "serviceTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "crack-injection",
              "wall-crack-repair",
              "bulkhead-repair",
              "carbon-fiber",
              "sewer-conduit",
              "concrete-repair",
              "garage-floor",
              "driveway",
              "patio",
              "pool-deck",
              "stairway",
              "walkway",
              "floor-crack",
              "fieldstone"
            ]
          },
          "minItems": 1
        },
        "beforeImage": {
          "type": "string"
        },
        "afterImage": {
          "type": "string"
        },
        "beforeAfterVerified": {
          "type": "boolean",
          "default": true
        },
        "summary": {
          "type": "string",
          "maxLength": 280
        },
        "published": {
          "type": "boolean",
          "default": true
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "date",
        "city",
        "state",
        "serviceTypes",
        "beforeImage",
        "afterImage",
        "summary"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}