---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import LocationModal from '../../components/LocationModal.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/Icon.astro';
import { isPublished } from '../../utils/blog';
import { phoneCT, phoneCTHref, phoneMA, phoneMAHref } from '../../utils/contact';
import { webpSrc, projectSrcset } from '../../utils/image';
import { getVideoSchemas } from '../../utils/video';

// Get all services sorted by order
const allServices = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const services = allServices.filter(s => !s.id.includes('free-foundation-consultations'));
const freeConsultation = allServices.find(s => s.id.includes('free-foundation-consultations'));

// Get blog posts flagged for services page
const diveDeeper = (await getCollection('blog', (entry) => isPublished(entry) && entry.data.showOnServicesPage))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 6);

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Services' }
];

// Service schema for the hub page
const servicesSchema = {
  "@type": "ItemList",
  "name": "Foundation Repair Services",
  "description": "Specialized foundation repair solutions with lifetime guarantee in Connecticut, Massachusetts, and across New England",
  "numberOfItems": services.length,
  "itemListElement": services.map((service, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Service",
      "name": service.data.title,
      "description": service.data.excerpt,
      "url": `https://www.attackacrack.com/services/${service.id.replace(/\.md$/, '')}`,
      "provider": {
        "@type": "HomeAndConstructionBusiness",
        "name": "Attack A Crack Foundation Repair"
      },
      "areaServed": [
        { "@type": "State", "name": "Connecticut" },
        { "@type": "State", "name": "Massachusetts" },
        { "@type": "State", "name": "Rhode Island" },
        { "@type": "State", "name": "New Hampshire" },
        { "@type": "State", "name": "Maine" }
      ]
    }
  }))
};
---

<Layout
  title="Foundation Repair Services"
  description="Specialized foundation repair with a lifetime guarantee. We repair wall cracks, leaky bulkheads, utility lines, and more in CT, MA & across New England."
  pageType="hub"
  customSchema={[servicesSchema, ...getVideoSchemas('services-hub')]}
  breadcrumbItems={breadcrumbItems}
>
	<LocationModal />
	<Navbar currentPage="services" />

	<main class="pt-20 lg:pt-24">
		<!-- Hero Section -->
		<section class="py-12 lg:py-32 bg-aac-dark text-white relative overflow-hidden">
			<div class="absolute top-0 right-0 w-1/2 h-full bg-aac-blue/10 skew-x-12 translate-x-1/2"></div>
			<div class="max-w-7xl mx-auto px-6 relative z-10">
				<Breadcrumbs items={breadcrumbItems} class="mb-8" variant="dark" />
				<h1 class="text-6xl lg:text-8xl font-black tracking-tighter mb-8 leading-none">
					FOUNDATION <br />
					<span class="text-aac-blue">REPAIR</span>
				</h1>
				<p class="text-xl text-zinc-300 max-w-2xl mb-12">
					Specialized foundation repair solutions with a lifetime guarantee. We don't just patch cracks; we solve the root cause with proven injection techniques.
				</p>
				<div class="flex flex-wrap gap-4">
					<a href={phoneCTHref} class="bg-aac-yellow text-aac-dark px-8 py-4 rounded-xl font-black uppercase tracking-widest text-[11px] border-2 border-aac-dark shadow-[4px_4px_0px_0px_rgba(255,255,255,0.1)] hover:translate-y-[-2px] transition-all inline-flex items-center gap-2">
						<Icon name="Phone" size={16} />
						Call CT: {phoneCT}
					</a>
					<a href={phoneMAHref} class="bg-aac-blue text-white px-8 py-4 rounded-xl font-black uppercase tracking-widest text-[11px] border-2 border-aac-dark shadow-[4px_4px_0px_0px_rgba(255,255,255,0.1)] hover:translate-y-[-2px] transition-all inline-flex items-center gap-2">
						<Icon name="Phone" size={16} />
						Call MA: {phoneMA}
					</a>
				</div>
			</div>
		</section>

		<!-- Why Our Method Video -->
		<section class="py-16 bg-white">
			<div class="max-w-4xl mx-auto px-6">
				<div class="grid md:grid-cols-2 gap-12 items-center">
					<div>
						<h2 class="text-3xl lg:text-4xl font-black tracking-tighter text-aac-dark mb-6">
							Why Our Method <span class="text-aac-blue">Is Better</span>
						</h2>
						<p class="text-zinc-600 leading-relaxed">
							At every step of our repair process, we've developed methods that ensure the absolute highest durability and integrity. From diamond saw preparation to 100 PSI injection pressure, we go far beyond industry standards.
						</p>
					</div>
					<div class="flex justify-center">
						<div class="aspect-[9/16] max-h-[450px] w-auto rounded-[24px] overflow-hidden border-4 border-zinc-100 shadow-xl bg-zinc-900">
							<iframe
								src="https://www.youtube.com/embed/NMgOgA6yGMs"
								title="Why our repair method is better at every step — Attack A Crack"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen
								loading="lazy"
								class="w-[108%] h-[108%] -mt-[4%] -ml-[4%]"
							></iframe>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Services Grid -->
		<section id="services" class="py-24 bg-zinc-50">
			<div class="max-w-7xl mx-auto px-6">
				<div class="text-center mb-16">
					<div class="inline-flex items-center gap-2 px-4 py-2 bg-aac-blue/5 text-aac-blue rounded-full text-[10px] font-black uppercase tracking-widest mb-6 border border-aac-blue/20">
						<Icon name="Wrench" size={14} /> Our Services
					</div>
					<h2 class="text-4xl lg:text-5xl font-black tracking-tighter text-aac-dark">
						Expert Foundation Solutions
					</h2>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
					{services.map((service) => (
						<a href={`/services/${service.id.replace(/\.md$/, '')}`} class="group bg-white rounded-[32px] border-2 border-zinc-100 hover:border-aac-blue transition-all shadow-sm hover:shadow-xl overflow-hidden">
							{service.data.heroImage ? (
								<div class="aspect-video overflow-hidden relative">
									<img src={webpSrc(service.data.heroImage)} srcset={projectSrcset(service.data.heroImage)} sizes="(max-width: 640px) calc(100vw - 48px), (max-width: 1024px) 344px, 400px" alt={service.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width="640" height="360" loading="lazy" />
									<div class="absolute bottom-4 left-4 w-12 h-12 bg-white/90 backdrop-blur-sm text-aac-blue rounded-xl flex items-center justify-center">
										<Icon name={service.data.icon} size={24} />
									</div>
								</div>
							) : (
								<div class="p-8 pb-0">
									<div class="w-14 h-14 bg-aac-blue/5 text-aac-blue rounded-2xl flex items-center justify-center mb-6 group-hover:bg-aac-blue group-hover:text-white transition-colors">
										<Icon name={service.data.icon} size={28} />
									</div>
								</div>
							)}
							<div class={service.data.heroImage ? "p-8" : "px-8 pb-8"}>
								<h3 class="text-2xl font-black mb-4 tracking-tight group-hover:text-aac-blue transition-colors">
									{service.data.title}
								</h3>
								<p class="text-zinc-600 mb-6 leading-relaxed">
									{service.data.excerpt}
								</p>
								<span class="inline-flex items-center gap-2 text-aac-blue font-black uppercase tracking-widest text-[10px] group-hover:gap-4 transition-all">
									{service.data.title} Details <Icon name="ArrowRight" size={14} />
								</span>
							</div>
						</a>
					))}

					<!-- Concrete Repair Card with MA Only Badge -->
					<a href="/concrete-repair" class="group bg-white rounded-[32px] border-2 border-zinc-100 hover:border-aac-blue transition-all shadow-sm hover:shadow-xl overflow-hidden">
						<div class="aspect-video overflow-hidden relative">
							<img src={webpSrc("/images/projects/hanover-concrete-repair-2025-06-before.jpg")} srcset={projectSrcset("/images/projects/hanover-concrete-repair-2025-06-before.jpg")} sizes="(max-width: 640px) calc(100vw - 48px), (max-width: 1024px) 344px, 400px" alt="Concrete repair and resurfacing" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width="640" height="360" loading="lazy" />
							<div class="absolute bottom-4 left-4 flex items-center gap-2">
								<div class="w-12 h-12 bg-white/90 backdrop-blur-sm text-aac-blue rounded-xl flex items-center justify-center">
									<Icon name="Layers" size={24} />
								</div>
								<span class="bg-aac-yellow text-aac-dark text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-full">MA Only</span>
							</div>
						</div>
						<div class="p-8">
							<h3 class="text-2xl font-black mb-4 tracking-tight group-hover:text-aac-blue transition-colors">
								Concrete Repair & Resurfacing
							</h3>
							<p class="text-zinc-600 mb-6 leading-relaxed">
								Repair and restore driveways, patios, pool decks, and walkways with our decorative concrete repair services in Massachusetts.
							</p>
							<span class="inline-flex items-center gap-2 text-aac-blue font-black uppercase tracking-widest text-[10px] group-hover:gap-4 transition-all">
								View Repair Options <Icon name="ArrowRight" size={14} />
							</span>
						</div>
					</a>
				</div>

				<!-- Free Consultation - Full Width -->
				{freeConsultation && (
					<a href={`/services/${freeConsultation.id.replace(/\.md$/, '')}`} class="group mt-8 grid md:grid-cols-2 bg-white rounded-[32px] border-2 border-zinc-100 hover:border-aac-blue transition-all shadow-sm hover:shadow-xl overflow-hidden">
						{freeConsultation.data.heroImage && (
							<div class="aspect-video md:aspect-auto overflow-hidden relative">
								<img src={webpSrc(freeConsultation.data.heroImage)} srcset={projectSrcset(freeConsultation.data.heroImage)} sizes="(max-width: 768px) calc(100vw - 48px), 400px" alt={freeConsultation.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width="640" height="360" loading="lazy" />
							</div>
						)}
						<div class="p-8 lg:p-12 flex flex-col justify-center">
							<div class="w-14 h-14 bg-aac-blue/5 text-aac-blue rounded-2xl flex items-center justify-center mb-6 group-hover:bg-aac-blue group-hover:text-white transition-colors">
								<Icon name={freeConsultation.data.icon} size={28} />
							</div>
							<h3 class="text-2xl lg:text-3xl font-black mb-4 tracking-tight group-hover:text-aac-blue transition-colors">
								{freeConsultation.data.title}
							</h3>
							<p class="text-zinc-600 mb-6 leading-relaxed text-lg">
								{freeConsultation.data.excerpt}
							</p>
							<span class="inline-flex items-center gap-2 text-aac-blue font-black uppercase tracking-widest text-[10px] group-hover:gap-4 transition-all">
								Learn More <Icon name="ArrowRight" size={14} />
							</span>
						</div>
					</a>
				)}
			</div>
		</section>

		<!-- Dive Deeper Section -->
		{diveDeeper.length > 0 && (
			<section class="py-24 bg-white">
				<div class="max-w-7xl mx-auto px-6">
					<div class="text-center mb-16">
						<div class="inline-flex items-center gap-2 px-4 py-2 bg-aac-blue/5 text-aac-blue rounded-full text-[10px] font-black uppercase tracking-widest mb-6 border border-aac-blue/20">
							<Icon name="BookOpen" size={14} /> Expert Resources
						</div>
						<h2 class="text-4xl lg:text-5xl font-black tracking-tighter text-aac-dark">
							Dive Deeper
						</h2>
						<p class="text-lg text-zinc-500 mt-4 max-w-2xl mx-auto">
							Expert guides on foundation repair costs, common problems, and when to take action.
						</p>
					</div>

					<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
						{diveDeeper.map((post) => (
							<a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="group bg-zinc-50 p-6 rounded-2xl border-2 border-zinc-100 hover:border-aac-blue transition-all">
								<h3 class="text-lg font-black mb-3 group-hover:text-aac-blue transition-colors leading-tight">
									{post.data.title}
								</h3>
								<p class="text-zinc-500 text-sm leading-relaxed mb-4 line-clamp-2">
									{post.data.excerpt}
								</p>
								<span class="inline-flex items-center gap-2 text-aac-blue font-black uppercase tracking-widest text-[10px] group-hover:gap-4 transition-all">
									Read More <Icon name="ArrowRight" size={14} />
								</span>
							</a>
						))}
					</div>
				</div>
			</section>
		)}

		<!-- Proven Methods Section -->
		<section class="py-24 bg-zinc-50">
			<div class="max-w-7xl mx-auto px-6">
				<div class="grid lg:grid-cols-2 gap-16 items-center">
					<div>
						<div class="inline-flex items-center gap-2 px-4 py-2 bg-aac-blue/5 text-aac-blue rounded-full text-[10px] font-black uppercase tracking-widest mb-6 border border-aac-blue/20">
							<Icon name="ShieldCheck" size={14} /> Why Choose Us
						</div>
						<h2 class="text-4xl lg:text-5xl font-black text-aac-dark mb-8 tracking-tighter">
							Proven Methods. <br />
							<span class="text-aac-blue">Lifetime Guarantee.</span>
						</h2>
						<div class="space-y-8">
							<div class="flex gap-6">
								<div class="w-12 h-12 bg-aac-blue text-white rounded-xl flex items-center justify-center shrink-0 font-black">01</div>
								<div>
									<h3 class="text-xl font-black mb-2">Foundation Crack Injection</h3>
									<p class="text-zinc-600">Our specialized urethane and epoxy injection process creates a permanent, flexible seal that moves with your foundation—guaranteed for life.</p>
								</div>
							</div>
							<div class="flex gap-6">
								<div class="w-12 h-12 bg-aac-blue text-white rounded-xl flex items-center justify-center shrink-0 font-black">02</div>
								<div>
									<h3 class="text-xl font-black mb-2">Carbon Fiber Reinforcement</h3>
									<p class="text-zinc-600">For structural cracks, we use aerospace-grade carbon fiber stitches to reinforce the wall and prevent further movement.</p>
								</div>
							</div>
							<div class="flex gap-6">
								<div class="w-12 h-12 bg-aac-blue text-white rounded-xl flex items-center justify-center shrink-0 font-black">03</div>
								<div>
									<h3 class="text-xl font-black mb-2">Talk to an Expert</h3>
									<p class="text-zinc-600">When you call Attack A Crack, you talk to an expert who knows foundations inside and out. Honest assessments, fair pricing.</p>
								</div>
							</div>
						</div>
					</div>
					<div class="aspect-[4/3] rounded-[32px] overflow-hidden border-8 border-white shadow-2xl bg-zinc-200">
						<img
							src={webpSrc("/images/projects/marshfield-crack-injection-2025-08-before.jpg")}
							srcset={projectSrcset("/images/projects/marshfield-crack-injection-2025-08-before.jpg")}
							sizes="(max-width: 1024px) calc(100vw - 48px), 600px"
							alt="Foundation crack requiring injection repair"
							class="w-full h-full object-cover"
							width="800"
							height="600"
							loading="lazy"
						/>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-24 bg-aac-dark text-white relative overflow-hidden">
			<div class="absolute inset-0 bg-aac-blue/10"></div>
			<div class="max-w-7xl mx-auto px-6 text-center relative z-10">
				<h2 class="text-4xl lg:text-6xl font-black tracking-tighter mb-8">
					Free Foundation <span class="text-aac-yellow">Consultation</span>
				</h2>
				<p class="text-xl text-zinc-300 max-w-2xl mx-auto mb-12">
					Not sure what's wrong with your foundation? We'll diagnose it for free. No pressure—just honest expert advice.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<button class="open-modal bg-aac-yellow text-aac-dark px-12 py-6 rounded-2xl font-black text-lg uppercase tracking-widest hover:translate-y-[-4px] transition-all shadow-[8px_8px_0px_0px_rgba(255,255,255,0.1)] border-4 border-white inline-flex items-center justify-center gap-3">
						<Icon name="MessageSquare" size={24} />
						Text Us Photos
					</button>
					<a href="/services/free-foundation-consultations" class="bg-white/10 backdrop-blur-sm text-white px-12 py-6 rounded-2xl font-black text-lg uppercase tracking-widest hover:bg-white/20 transition-all border border-white/20 inline-flex items-center justify-center gap-3">
						<Icon name="Info" size={24} />
						Free Consultation Info
					</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
