---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import LocationModal from '../components/LocationModal.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Icon from '../components/Icon.astro';

// Get blog posts
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Get published projects
const allProjects = (await getCollection('projects', ({ data }) => data.published))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Combine into unified items
interface UpdateItem {
	type: 'article' | 'project';
	date: Date;
	title: string;
	excerpt: string;
	href: string;
	image: string;
	imageAlt: string;
	category?: string;
	city?: string;
	state?: string;
	serviceType?: string;
}

const categoryLabels: Record<string, string> = {
	'guides': 'Guide',
	'case-studies': 'Case Study',
	'cost-guides': 'Cost Guide',
	'maintenance-tips': 'Tips',
	'news': 'News',
};

const serviceTypeLabels: Record<string, string> = {
	'crack-injection': 'Crack Injection',
	'wall-crack-repair': 'Wall Crack Repair',
	'bulkhead-repair': 'Bulkhead Repair',
	'carbon-fiber': 'Carbon Fiber',
	'sewer-conduit': 'Sewer & Conduit',
	'concrete-repair': 'Concrete Repair',
};

const articles: UpdateItem[] = allPosts.map(post => ({
	type: 'article',
	date: post.data.publishDate,
	title: post.data.title,
	excerpt: post.data.excerpt,
	href: `/blog/${post.id.replace(/\.md$/, '')}`,
	image: post.data.heroImage || `https://picsum.photos/seed/${post.id}/600/400`,
	imageAlt: post.data.heroImageAlt || post.data.title,
	category: post.data.category,
}));

const projects: UpdateItem[] = allProjects.map(project => ({
	type: 'project',
	date: project.data.date,
	title: project.data.title,
	excerpt: project.data.summary,
	href: `/projects/${project.id.replace(/\.md$/, '')}`,
	image: project.data.afterImage,
	imageAlt: `${project.data.title} - After repair`,
	city: project.data.city,
	state: project.data.state,
	serviceType: project.data.serviceType,
}));

const allItems = [...articles, ...projects]
	.sort((a, b) => b.date.valueOf() - a.date.valueOf());

function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	});
}

const breadcrumbItems = [
	{ label: 'Home', href: '/' },
	{ label: 'Updates' }
];

const itemListSchema = {
	"@type": "ItemList",
	"name": "Foundation Repair Updates",
	"description": "Articles, guides, and recent project case studies from Attack A Crack Foundation Repair.",
	"numberOfItems": allItems.length,
	"itemListElement": allItems.slice(0, 50).map((item, index) => ({
		"@type": "ListItem",
		"position": index + 1,
		"url": `https://www.attackacrack.com${item.href}`,
		"name": item.title,
	})),
};
---

<Layout
	title="Foundation Repair Updates"
	description="Expert articles, cost guides, and recent project case studies from Attack A Crack. Foundation repair insights for New England homeowners."
	customSchema={itemListSchema}
	breadcrumbItems={breadcrumbItems}
>
	<LocationModal />
	<Navbar currentPage="updates" />

	<main class="pt-20 lg:pt-24">
		<!-- Hero Section -->
		<section class="py-20 lg:py-32 bg-white border-b-4 border-zinc-100">
			<div class="max-w-7xl mx-auto px-6">
				<Breadcrumbs items={breadcrumbItems} class="mb-8" />
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<div>
						<h1 class="text-6xl lg:text-8xl font-black tracking-tighter mb-8 leading-none">
							UP<br />
							<span class="text-aac-blue">DATES.</span>
						</h1>
						<p class="text-xl text-zinc-500 max-w-lg">
							Expert articles, cost guides, and before-and-after project case studies from New England's foundation repair specialists.
						</p>
					</div>
					<div>
						<!-- Filter Buttons -->
						<div class="flex flex-wrap gap-3" id="filter-buttons">
							<button data-filter="all" class="filter-btn active px-4 py-2 bg-aac-dark text-white rounded-full text-sm font-bold transition-colors">
								All ({allItems.length})
							</button>
							<button data-filter="article" class="filter-btn px-4 py-2 bg-zinc-100 text-zinc-700 rounded-full text-sm font-bold hover:bg-aac-blue hover:text-white transition-colors">
								Articles ({articles.length})
							</button>
							{projects.length > 0 && (
								<button data-filter="project" class="filter-btn px-4 py-2 bg-zinc-100 text-zinc-700 rounded-full text-sm font-bold hover:bg-aac-blue hover:text-white transition-colors">
									Projects ({projects.length})
								</button>
							)}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Updates Grid -->
		<section class="py-24 bg-zinc-50">
			<div class="max-w-7xl mx-auto px-6">
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" id="updates-grid">
					{allItems.map((item) => (
						<a
							href={item.href}
							data-type={item.type}
							class="update-card group bg-white rounded-[32px] overflow-hidden border-2 border-zinc-100 hover:border-aac-blue transition-all"
						>
							<div class="aspect-video overflow-hidden relative">
								<img
									src={item.image}
									alt={item.imageAlt}
									class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
									referrerpolicy="no-referrer"
								/>
								<div class="absolute top-4 left-4 bg-aac-dark/80 backdrop-blur-md text-white text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-lg border border-white/20">
									{item.type === 'article'
										? categoryLabels[item.category || ''] || 'Article'
										: serviceTypeLabels[item.serviceType || ''] || 'Project'
									}
								</div>
							</div>
							<div class="p-8">
								<div class="flex items-center gap-4 mb-4">
									<span class="text-[10px] font-black uppercase tracking-widest text-aac-blue">
										{item.type === 'article' ? 'Article' : `${item.city}, ${item.state}`}
									</span>
									<span class="text-[10px] text-zinc-500 font-bold">
										{formatDate(item.date)}
									</span>
								</div>
								<h2 class="text-xl font-black mb-3 leading-tight group-hover:text-aac-blue transition-colors">
									{item.title}
								</h2>
								<p class="text-zinc-500 text-sm leading-relaxed mb-4 line-clamp-3">
									{item.excerpt}
								</p>
								<span class="inline-flex items-center gap-2 text-aac-dark font-black uppercase tracking-widest text-[10px] group-hover:gap-4 transition-all">
									{item.type === 'article' ? 'Read Article' : 'View Project'} <Icon name="ArrowRight" size={14} />
								</span>
							</div>
						</a>
					))}
				</div>

				{allItems.length === 0 && (
					<div class="text-center py-16">
						<p class="text-zinc-500 text-lg">No updates yet. Check back soon!</p>
					</div>
				)}
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-16 bg-aac-yellow">
			<div class="max-w-4xl mx-auto px-6 text-center">
				<h2 class="text-3xl lg:text-4xl font-black text-aac-dark mb-6">
					Have a Foundation Question?
				</h2>
				<p class="text-lg text-aac-dark/70 mb-8">
					Get a free, no-pressure assessment from our experts. We'll give you honest answers about your foundation.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<button class="open-modal bg-aac-dark text-white px-8 py-4 rounded-xl font-black uppercase tracking-widest text-sm hover:translate-y-[-2px] transition-all inline-flex items-center justify-center gap-2">
						<Icon name="MessageSquare" size={20} />
						Text Us Photos
					</button>
					<a href="/services/free-foundation-consultations" class="bg-white text-aac-dark px-8 py-4 rounded-xl font-black uppercase tracking-widest text-sm hover:translate-y-[-2px] transition-all inline-flex items-center justify-center gap-2 border-2 border-aac-dark">
						Free Consultation
					</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<script>
	// Client-side filter for articles vs projects
	const buttons = document.querySelectorAll('.filter-btn');
	const cards = document.querySelectorAll('.update-card');

	buttons.forEach(btn => {
		btn.addEventListener('click', () => {
			const filter = btn.getAttribute('data-filter');

			// Update active button
			buttons.forEach(b => {
				b.classList.remove('active', 'bg-aac-dark', 'text-white');
				b.classList.add('bg-zinc-100', 'text-zinc-700');
			});
			btn.classList.add('active', 'bg-aac-dark', 'text-white');
			btn.classList.remove('bg-zinc-100', 'text-zinc-700');

			// Filter cards
			cards.forEach(card => {
				const type = card.getAttribute('data-type');
				if (filter === 'all' || type === filter) {
					(card as HTMLElement).style.display = '';
				} else {
					(card as HTMLElement).style.display = 'none';
				}
			});
		});
	});
</script>
