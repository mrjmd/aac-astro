---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import TeamExpanded from '../components/TeamExpanded.astro';
import Footer from '../components/Footer.astro';
import LocationModal from '../components/LocationModal.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Icon from '../components/Icon.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { reviewCount } from '../utils/reviews';
import { phoneCT, phoneCTHref, phoneMA, phoneMAHref } from '../utils/contact';
import { webpSrc, projectSrcset } from '../utils/image';
import { getFeatured } from '../utils/testimonials';

const testimonials = getFeatured(4);

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'About' }
];

// Organization schema
const aboutSchema = {
  "@type": "HomeAndConstructionBusiness",
  "name": "Attack A Crack Foundation Repair",
  "foundingDate": "2002",
  "description": "Family-owned foundation repair company serving Connecticut, Massachusetts, and all of New England for over 20 years.",
  "telephone": phoneCT,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Amston",
    "addressRegion": "CT",
    "postalCode": "06231",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "State", "name": "Connecticut" },
    { "@type": "State", "name": "Massachusetts" },
    { "@type": "State", "name": "Rhode Island" },
    { "@type": "State", "name": "New Hampshire" },
    { "@type": "State", "name": "Maine" }
  ],
  "numberOfEmployees": {
    "@type": "QuantitativeValue",
    "value": 5
  },
  "founder": {
    "@type": "Person",
    "name": "Luc Richard"
  }
};
---

<Layout 
  title="About Our Team" 
  description="Meet the Attack A Crack team — family-owned foundation repair experts serving New England for over 20 years. Talk to an expert, get honest advice."
  customSchema={aboutSchema}
  breadcrumbItems={breadcrumbItems}
>
	<LocationModal />
	<Navbar currentPage="about" />

	<main class="pt-20 lg:pt-24">
		<!-- Hero Section -->
		<section class="py-20 lg:py-32 bg-aac-dark text-white relative overflow-hidden">
			<div class="absolute top-0 right-0 w-1/2 h-full bg-aac-blue/10 skew-x-12 translate-x-1/2"></div>
			<div class="max-w-7xl mx-auto px-6 relative z-10">
				<Breadcrumbs items={breadcrumbItems} class="mb-8 [&_a]:text-zinc-300 [&_a:hover]:text-white [&_span]:text-white [&_svg]:text-zinc-300" />
				<h1 class="text-6xl lg:text-8xl font-black tracking-tighter mb-8 leading-none">
					ABOUT <br />
					<span class="text-aac-blue">OUR TEAM</span>
				</h1>
				<p class="text-xl text-zinc-300 max-w-2xl mb-8">
					Family-owned and operated for over 20 years. We're not a franchise; we're your neighbors, dedicated to protecting your home.
				</p>
				<div class="flex flex-wrap gap-6">
					<div class="flex items-center gap-3 text-white">
						<div class="w-12 h-12 bg-aac-blue/20 rounded-xl flex items-center justify-center">
							<Icon name="Clock" size={24} class="text-aac-blue" />
						</div>
						<div>
							<p class="text-2xl font-black">50+</p>
							<p class="text-sm text-zinc-300">Years Combined Experience</p>
						</div>
					</div>
					<div class="flex items-center gap-3 text-white">
						<div class="w-12 h-12 bg-aac-yellow/20 rounded-xl flex items-center justify-center">
							<Icon name="Star" size={24} class="text-aac-yellow" />
						</div>
						<div>
							<p class="text-2xl font-black">{reviewCount}+</p>
							<p class="text-sm text-zinc-300">5-Star Reviews</p>
						</div>
					</div>
					<div class="flex items-center gap-3 text-white">
						<div class="w-12 h-12 bg-aac-blue/20 rounded-xl flex items-center justify-center">
							<Icon name="ShieldCheck" size={24} class="text-aac-blue" />
						</div>
						<div>
							<p class="text-2xl font-black">Lifetime</p>
							<p class="text-sm text-zinc-300">Guarantee</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Our Story Section -->
		<section class="py-24 bg-white">
			<div class="max-w-7xl mx-auto px-6">
				<div class="grid lg:grid-cols-2 gap-16 items-center">
					<div>
						<div class="inline-flex items-center gap-2 px-4 py-2 bg-aac-blue/10 text-aac-blue rounded-full text-[10px] font-black uppercase tracking-widest mb-6 border border-aac-blue/20">
							<Icon name="BookOpen" size={14} /> Our Story
						</div>
						<h2 class="text-4xl lg:text-5xl font-black text-aac-dark mb-8 tracking-tighter">
							Building Legacies, <br />
							<span class="text-aac-blue">One Foundation at a Time</span>
						</h2>
						<div class="space-y-6 text-zinc-600 leading-relaxed">
							<p>
								Luc Richard grew up around concrete, working alongside his father's concrete company from age 16. He learned to pour, finish, and understand how concrete behaves in New England's climate. After years mastering the material, Luc shifted into foundation repair — specializing in the high-pressure injection techniques that would become Attack A Crack's signature.
							</p>
							<p>
								Over 20+ years, the business evolved into the specialized foundation repair company it is today. Lead Technician Justin La Fontaine has been with Luc for over 20 years—joining right out of high school—and together they've developed the methods that set Attack A Crack apart: diamond saw preparation, copper injection ports, and 100 PSI injection pressure that far exceeds the industry standard.
							</p>
							<p>
								In 2024, Attack A Crack opened a satellite office in Massachusetts — a state where the team had already been doing business for years. Managing Partner Matt Davis leads Bay State operations, bringing proven methods and a lifetime guarantee to even more New England homeowners.
							</p>
						</div>
					</div>
					<div class="relative">
						<div class="aspect-[4/3] rounded-[32px] overflow-hidden border-8 border-white shadow-2xl bg-zinc-200">
							<img
								src={webpSrc("/images/projects/weymouth-carbon-fiber-2025-08-after.jpg")}
								srcset={projectSrcset("/images/projects/weymouth-carbon-fiber-2025-08-after.jpg")}
								sizes="(max-width: 1024px) calc(100vw - 48px), 600px"
								alt="Attack A Crack carbon fiber foundation repair"
								class="w-full h-full object-cover"
								width="800"
								height="600"
								loading="lazy"
							/>
						</div>
						<div class="absolute -bottom-8 -left-8 bg-aac-dark text-white p-6 rounded-2xl shadow-xl">
							<p class="text-4xl font-black">2002</p>
							<p class="text-sm text-zinc-300">Founded in CT</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Our Values Section -->
		<section class="py-24 bg-aac-dark text-white relative overflow-hidden">
			<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(59,130,246,0.15),transparent_60%)]"></div>
			<div class="max-w-7xl mx-auto px-6 relative z-10">
				<div class="text-center mb-16">
					<div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 text-white rounded-full text-[10px] font-black uppercase tracking-widest mb-6 border border-white/20">
						<Icon name="Heart" size={14} /> Our Values
					</div>
					<h2 class="text-4xl lg:text-5xl font-black tracking-tighter">
						What We Stand For
					</h2>
				</div>

				<div class="grid md:grid-cols-3 gap-8">
					<!-- Honesty -->
					<div class="bg-white/5 backdrop-blur-sm p-8 rounded-2xl border border-white/10">
						<div class="w-16 h-16 bg-aac-blue text-white rounded-2xl flex items-center justify-center mb-6">
							<Icon name="MessageCircle" size={32} />
						</div>
						<h3 class="text-2xl font-black mb-4">Honesty</h3>
						<p class="text-zinc-300 leading-relaxed">
							No-strings-attached advice, every time. If it's something you can handle yourself, we'll tell you how. We'd rather earn your trust than your money on a job you don't need. See <a href="/what-we-dont-do" class="text-aac-yellow hover:underline">what we don't do</a> — that's part of being honest.
						</p>
					</div>

					<!-- Responsiveness -->
					<div class="bg-white/5 backdrop-blur-sm p-8 rounded-2xl border border-white/10">
						<div class="w-16 h-16 bg-aac-yellow text-aac-dark rounded-2xl flex items-center justify-center mb-6">
							<Icon name="Zap" size={32} />
						</div>
						<h3 class="text-2xl font-black mb-4">Responsiveness</h3>
						<p class="text-zinc-300 leading-relaxed">
							15-minute response time on calls and texts. When water is coming through your foundation, every minute matters. We treat your emergency like our own.
						</p>
					</div>

					<!-- Quality -->
					<div class="bg-white/5 backdrop-blur-sm p-8 rounded-2xl border border-white/10">
						<div class="w-16 h-16 bg-aac-blue text-white rounded-2xl flex items-center justify-center mb-6">
							<Icon name="Award" size={32} />
						</div>
						<h3 class="text-2xl font-black mb-4">Quality</h3>
						<p class="text-zinc-300 leading-relaxed">
							Diamond saw preparation, copper injection ports, and 100 PSI pressure—our methods go far beyond the industry standard. Every repair comes with a lifetime guarantee because we're confident in the work we do.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Team Section -->
		<TeamExpanded />

		<!-- The Expert Promise -->
		<section class="py-24 bg-aac-blue text-white">
			<div class="max-w-4xl mx-auto px-6 text-center">
				<div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 text-white rounded-full text-[10px] font-black uppercase tracking-widest mb-8 border border-white/20">
					<Icon name="UserCheck" size={14} /> Our Promise
				</div>
				<h2 class="text-4xl lg:text-5xl font-black mb-8 tracking-tighter">
					Talk to an Expert
				</h2>
				<p class="text-xl opacity-90 leading-relaxed mb-8">
					When you contact us, you talk to an expert who knows foundations inside and out. We give honest assessments and fair pricing. If you can fix it yourself, we'll tell you how.
				</p>
				<p class="text-lg italic">
					"We don't just repair concrete; we build legacies—protecting homes and serving as part of a family tradition of excellence."
				</p>
			</div>
		</section>

		<!-- Customer Testimonials -->
		<section class="py-24 bg-white">
			<div class="max-w-7xl mx-auto px-6">
				<div class="text-center mb-16">
					<div class="inline-flex items-center gap-2 px-4 py-2 bg-aac-yellow/10 text-aac-dark rounded-full text-[10px] font-black uppercase tracking-widest mb-6 border border-aac-yellow">
						<Icon name="MessageSquare" size={14} /> Real Reviews
					</div>
					<h2 class="text-4xl lg:text-5xl font-black tracking-tighter text-aac-dark">
						What Our Customers Say
					</h2>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
					{testimonials.map(t => (
						<TestimonialCard
							quote={t.quote}
							author={t.author}
							location={t.location}
							rating={t.rating}
						/>
					))}
				</div>
			</div>
		</section>

		<!-- E-E-A-T Section -->
		<section class="py-24 bg-zinc-50">
			<div class="max-w-7xl mx-auto px-6">
				<div class="text-center mb-16">
					<h2 class="text-3xl lg:text-4xl font-black tracking-tighter text-aac-dark">
						Why Trust Attack A Crack?
					</h2>
					<p class="text-zinc-500 mt-4 max-w-2xl mx-auto">
						We earn trust through decades of results, not sales pitches.
					</p>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
					<div class="bg-white p-6 rounded-2xl border-2 border-zinc-100 text-center">
						<div class="w-16 h-16 bg-aac-blue/10 text-aac-blue rounded-2xl flex items-center justify-center mx-auto mb-4">
							<Icon name="GraduationCap" size={32} />
						</div>
						<p class="text-3xl font-black text-aac-dark mb-1">50+</p>
						<h3 class="font-black text-lg mb-2">Combined Years Experience</h3>
						<p class="text-sm text-zinc-600">Our team brings over 50 combined years of hands-on foundation repair experience across New England.</p>
					</div>
					<div class="bg-white p-6 rounded-2xl border-2 border-zinc-100 text-center">
						<div class="w-16 h-16 bg-aac-blue/10 text-aac-blue rounded-2xl flex items-center justify-center mx-auto mb-4">
							<Icon name="Briefcase" size={32} />
						</div>
						<p class="text-3xl font-black text-aac-dark mb-1">HIC</p>
						<h3 class="font-black text-lg mb-2">Licensed & Certified</h3>
						<p class="text-sm text-zinc-600">HIC licensed in CT and MA. Fully insured across all five New England states we serve.</p>
					</div>
					<div class="bg-white p-6 rounded-2xl border-2 border-zinc-100 text-center">
						<div class="w-16 h-16 bg-aac-blue/10 text-aac-blue rounded-2xl flex items-center justify-center mx-auto mb-4">
							<Icon name="FileCheck" size={32} />
						</div>
						<p class="text-3xl font-black text-aac-dark mb-1">Local</p>
						<h3 class="font-black text-lg mb-2">Memberships</h3>
						<p class="text-sm text-zinc-600">ASHI affiliate member. Greater Boston Association of Realtors (GBAR) member. Active in local chambers of commerce and industry partner networks.</p>
					</div>
					<div class="bg-white p-6 rounded-2xl border-2 border-zinc-100 text-center">
						<div class="w-16 h-16 bg-aac-yellow/10 text-aac-dark rounded-2xl flex items-center justify-center mx-auto mb-4">
							<Icon name="Star" size={32} />
						</div>
						<p class="text-3xl font-black text-aac-dark mb-1">{reviewCount}+</p>
						<h3 class="font-black text-lg mb-2">5-Star Reviews</h3>
						<p class="text-sm text-zinc-600">5.0-star average on Google. Lifetime transferable warranty on every repair. Real reviews from real homeowners.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-24 bg-aac-dark text-white">
			<div class="max-w-4xl mx-auto px-6 text-center">
				<h2 class="text-4xl lg:text-5xl font-black tracking-tighter mb-6">
					Contact the Team <span class="text-aac-yellow">Today</span>
				</h2>
				<p class="text-xl text-zinc-300 mb-10">
					Get a free consultation — text us photos or call for honest expert advice on your foundation.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href={phoneCTHref} class="bg-aac-yellow text-aac-dark px-12 py-6 rounded-2xl font-black text-lg uppercase tracking-widest hover:translate-y-[-4px] transition-all shadow-[8px_8px_0px_0px_rgba(255,255,255,0.1)] border-4 border-white inline-flex items-center justify-center gap-3">
						<Icon name="Phone" size={24} />
						CT: {phoneCT}
					</a>
					<a href={phoneMAHref} class="bg-aac-blue text-white px-12 py-6 rounded-2xl font-black text-lg uppercase tracking-widest hover:translate-y-[-4px] transition-all border-2 border-aac-dark shadow-[4px_4px_0px_0px_rgba(255,255,255,0.1)] inline-flex items-center justify-center gap-3">
						<Icon name="Phone" size={24} />
						MA: {phoneMA}
					</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
