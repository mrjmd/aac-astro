---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Team from '../components/Team.astro';
import Services from '../components/Services.astro';
import Footer from '../components/Footer.astro';
import LocationModal from '../components/LocationModal.astro';
import HomeFaq from '../components/HomeFaq.astro';
import Icon from '../components/Icon.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { reviewCount, phoneCT, phoneMA, googleReviewsUrlCT, googleReviewsUrlMA } from '../utils/reviews';
import { getFeatured } from '../utils/testimonials';
import { homeFaqs, getFaqSchema } from '../utils/faqs';

const featuredTestimonials = getFeatured(4);
const faqSchema = getFaqSchema(homeFaqs);

const CT_NUMBER = phoneCT;
const MA_NUMBER = phoneMA;
---

<Layout 
	title="Foundation Crack Repair Made Simple" 
	description="Attack A Crack provides expert foundation wall crack repair, bulkhead sealing, and concrete repair in CT & MA. 20+ years experience with a lifetime guarantee."
	preloadHeroImage
	breadcrumbItems={[{ label: 'Home' }]}
	customSchema={faqSchema}
>
	<LocationModal />
	<Navbar currentPage="home" />
	
	<main>
		<Hero />
		
		<!-- Stats Bar -->
		<div class="bg-aac-yellow border-y-8 border-aac-dark py-12">
			<div class="max-w-7xl mx-auto px-6 grid grid-cols-2 lg:grid-cols-4 gap-12">
				{[
					{ label: "EXPERIENCE", val: "20+ Years" },
					{ label: "GUARANTEE", val: "Lifetime" },
					{ label: "REVIEWS", val: `${reviewCount}+ 5-Star` },
					{ label: "DIAGNOSIS", val: "100% Free" }
				].map((stat) => (
					<div class="flex flex-col items-center lg:items-start text-center lg:text-left">
						<span class="text-[10px] font-black uppercase tracking-[0.2em] text-aac-dark/70 mb-2">{stat.label}</span>
						<span class="text-2xl font-black text-aac-dark tracking-tighter">{stat.val}</span>
					</div>
				))}
			</div>
		</div>

		<Team />
		<Services />
		
		<!-- Testimonials -->
		<section id="reviews" data-animate class="py-16 md:py-24 bg-white relative overflow-hidden">
			<div class="max-w-7xl mx-auto px-6">
				<div class="grid lg:grid-cols-[1fr_2fr] gap-12 items-start">
					<div>
						<p class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-zinc-400 mb-6">
							<Icon name="MessageSquare" size={14} /> WHAT PEOPLE SAY
						</p>
						<h2 class="text-4xl lg:text-5xl font-display font-black text-aac-dark tracking-tighter leading-[0.9] mb-8">
							Don't Just Take <br />
							<span class="text-aac-blue">Our Word For It.</span>
						</h2>
						<div class="flex items-center gap-4 mb-6">
							<div class="flex items-center gap-1">
								{[...Array(5)].map(() => <Icon name="Star" size={20} class="fill-aac-yellow text-aac-dark" />)}
							</div>
							<span class="font-black text-aac-dark text-sm">5.0 Rating on Google</span>
						</div>
						<div class="flex flex-col gap-3">
							<a href={googleReviewsUrlCT} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-aac-blue hover:text-aac-dark transition-colors">
								Read All CT Reviews <Icon name="ExternalLink" size={12} />
							</a>
							<a href={googleReviewsUrlMA} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-aac-blue hover:text-aac-dark transition-colors">
								Read All MA Reviews <Icon name="ExternalLink" size={12} />
							</a>
						</div>
					</div>
					
					<div class="grid md:grid-cols-2 gap-6 flex-grow">
						{featuredTestimonials.map((rev) => (
							<TestimonialCard
								quote={rev.quote}
								author={rev.author}
								location={rev.location}
								rating={rev.rating}
							/>
						))}
					</div>
				</div>
			</div>
		</section>

		<HomeFaq />

		<!-- Final CTA -->
		<section data-animate class="py-20 md:py-32 bg-aac-yellow relative overflow-hidden border-y-8 border-aac-dark">
			<!-- Dot Pattern -->
			<div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, #1a1a1a 2px, transparent 2px); background-size: 40px 40px;"></div>
			
			<div class="max-w-7xl mx-auto px-6 text-center relative z-10">
				<h2 class="text-5xl sm:text-7xl lg:text-9xl font-display font-black tracking-tighter text-aac-dark mb-12 leading-[0.8]">
					FIX YOUR <br />
					<span class="text-aac-blue">FOUNDATION</span> <br />
					TODAY.
				</h2>
				<p class="text-xl font-bold text-aac-dark/70 mb-12 max-w-2xl mx-auto">
					No salespeople. No pressure. Just honest experts ready to help you secure your home.
				</p>
				<div class="flex flex-col lg:flex-row items-center justify-center gap-8">
					<button 
						class="open-modal bg-aac-blue text-white px-12 py-6 rounded-[24px] font-black text-2xl uppercase tracking-widest hover:translate-y-[-6px] transition-all shadow-[12px_12px_0px_0px_rgba(26,26,26,1)] border-4 border-aac-dark flex items-center justify-center gap-4"
					>
						<Icon name="MessageSquare" size={32} />
						TEXT PHOTOS
					</button>
					<div class="flex flex-col gap-3">
						<a href={`tel:${CT_NUMBER}`} class="bg-white text-aac-dark px-8 py-3.5 rounded-xl font-black text-sm uppercase tracking-widest border-4 border-aac-dark hover:bg-zinc-50 transition-all flex items-center justify-between gap-8 min-w-[280px]">
							<div class="flex items-center gap-3">
								<Icon name="Phone" size={18} class="text-aac-blue" />
								<span>CT: {CT_NUMBER}</span>
							</div>
							<Icon name="ArrowRight" size={16} />
						</a>
						<a href={`tel:${MA_NUMBER}`} class="bg-white text-aac-dark px-8 py-3.5 rounded-xl font-black text-sm uppercase tracking-widest border-4 border-aac-dark hover:bg-zinc-50 transition-all flex items-center justify-between gap-8 min-w-[280px]">
							<div class="flex items-center gap-3">
								<Icon name="Phone" size={18} class="text-aac-blue" />
								<span>MA: {MA_NUMBER}</span>
							</div>
							<Icon name="ArrowRight" size={16} />
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<script>
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('is-visible');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.1 }
	);
	document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));
</script>
