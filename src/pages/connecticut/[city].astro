---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import LocationModal from '../../components/LocationModal.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/Icon.astro';
import ProjectCards from '../../components/ProjectCards.astro';
import ProcessBar from '../../components/ProcessBar.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import { reviewCount, reviewCountDisplay, rating, aggregateRatingSchema, googleReviewsUrlCT } from '../../utils/reviews';
import { phoneCT, phoneCTHref } from '../../utils/contact';
import { webpSrc, projectSrcset } from '../../utils/image';
import { getForLocation } from '../../utils/testimonials';
import { getForLocation as getProjectsForLocation, getProjectImageForCity } from '../../utils/projects';
import { getBlogForLocation } from '../../utils/blog-linking';
import { crackRepairRange, bulkheadRange, carbonFiberRange, sewerConduitRange } from '../../utils/pricing';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  const ctLocations = locations.filter(loc => loc.data.stateAbbr === 'CT');

  return ctLocations.map((location) => ({
    params: { city: location.id.replace(/\.md$/, '').replace(/^connecticut\//, '') },
    props: { location },
  }));
}

const { location } = Astro.props;
const { Content } = await render(location);

// Get testimonial: use frontmatter if available, otherwise fall back to centralized data
const testimonial = location.data.testimonial
  || getForLocation(location.data.city, 'CT', 1)[0]
  || null;

// Get matching projects for this city
const cityProjects = await getProjectsForLocation(location.data.city, 'CT', 3, location.data.coordinates);
const heroImage = await getProjectImageForCity(location.data.city, 'CT', location.data.coordinates, location.data.heroImage, location.data.heroImageAlt);

// Get related blog posts for this location
const cityBlogPosts = await getBlogForLocation(location.data.city, 'CT', 3);

// Get services (foundation repair only for CT - no resurfacing)
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
// Note: Concrete repair services are MA-only and are in a separate collection ('concrete-repair')

// Get nearby city pages
const allLocations = await getCollection('locations');
const nearbyLocations = location.data.nearbyCities
  ? allLocations.filter(loc =>
      loc.data.stateAbbr === 'CT' &&
      location.data.nearbyCities?.includes(loc.data.city)
    )
  : [];

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Connecticut', href: '/connecticut' },
  { label: location.data.city }
];

// Build significantLink array
const significantLinks = [
  // Services available in CT
  ...services.slice(0, 4).map(s => `https://www.attackacrack.com/services/${s.id.replace(/\.md$/, '')}`),
  // Nearby cities
  ...nearbyLocations.slice(0, 3).map(l => `https://www.attackacrack.com/connecticut/${l.id.replace(/\.md$/, '').replace(/^connecticut\//, '')}`),
  // State hub
  "https://www.attackacrack.com/connecticut"
];

// Build mentions array
const mentions = [
  // City itself
  { "@type": "Place", "name": `${location.data.city}, Connecticut` },
  // Neighborhoods
  ...(location.data.neighborhoods || []).map(n => ({ "@type": "Neighborhood", "name": n })),
  // Local landmarks
  ...(location.data.localLandmarks || []).map(l => ({ "@type": "Landmark", "name": l })),
  // Common foundation types
  ...(location.data.commonFoundationTypes || []).map(f => ({ "@type": "Thing", "name": f }))
];

// LocalBusiness schema for this city with LLM-ready properties
const citySchema = {
  "@type": "HomeAndConstructionBusiness",
  "name": `Attack A Crack Foundation Repair - ${location.data.city}, CT`,
  "image": "https://www.attackacrack.com/images/logo.jpg",
  "@id": `https://www.attackacrack.com/connecticut/${location.id.replace(/\.md$/, '').replace(/^connecticut\//, '')}#organization`,
  "url": `https://www.attackacrack.com/connecticut/${location.id.replace(/\.md$/, '').replace(/^connecticut\//, '')}`,
  "telephone": location.data.phoneNumber || phoneCT,
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": location.data.city,
    "addressRegion": "CT",
    "addressCountry": "US"
  },
  "areaServed": {
    "@type": "City",
    "name": location.data.city,
    "containedInPlace": {
      "@type": "State",
      "name": "Connecticut"
    }
  },
  ...(location.data.coordinates && {
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": location.data.coordinates.lat,
      "longitude": location.data.coordinates.lng
    }
  }),
  "aggregateRating": aggregateRatingSchema,
  // LLM-ready properties
  "significantLink": significantLinks,
  "mentions": mentions
};

// FAQ schema if FAQs exist
const faqSchema = location.data.faqs && location.data.faqs.length > 0 ? {
  "@type": "FAQPage",
  "mainEntity": location.data.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;

const schemas = faqSchema ? [citySchema, faqSchema] : [citySchema];
---

<Layout
  title={location.data.metaTitle}
  description={location.data.metaDescription}
  city={location.data.city}
  state="CT"
  coordinates={location.data.coordinates}
  customSchema={schemas}
  breadcrumbItems={breadcrumbItems}
>
	<LocationModal />
	<Navbar />

	<main class="pt-20 lg:pt-24">
		<!-- Hero Section -->
		<section class="py-16 lg:py-24 bg-aac-dark text-white relative overflow-hidden">
			<div class="absolute top-0 right-0 w-1/2 h-full bg-aac-blue/10 skew-x-12 translate-x-1/2"></div>
			<div class="max-w-7xl mx-auto px-6 relative z-10">
				<Breadcrumbs items={breadcrumbItems} class="mb-8" variant="dark" />

				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<div>
						<div class="inline-flex items-center gap-2 px-4 py-2 bg-aac-yellow/20 text-aac-yellow rounded-full text-[10px] font-black uppercase tracking-widest mb-6 border border-aac-yellow/30">
							<Icon name="MapPin" size={14} /> {location.data.city}, CT
						</div>
						<h1 class="text-4xl lg:text-6xl font-black tracking-tighter mb-6 leading-none">
							Foundation Repair in <span class="text-aac-blue">{location.data.city}</span>, Connecticut
						</h1>

						{location.data.population && (
							<p class="text-lg text-zinc-300 mb-4">
								Serving {location.data.population.toLocaleString()}+ {location.data.city} residents with expert foundation repair.
							</p>
						)}

						<div class="flex flex-wrap gap-4 mb-8">
							<a href={googleReviewsUrlCT} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-aac-yellow hover:text-yellow-300 transition-colors">
								<Icon name="Star" size={18} />
								<span class="font-bold text-sm">{reviewCountDisplay} 5-Star Reviews</span>
							</a>
							<div class="flex items-center gap-2 text-white">
								<Icon name="ShieldCheck" size={18} />
								<span class="font-bold text-sm">Lifetime Guarantee</span>
							</div>
						</div>

						<div class="flex flex-wrap gap-4">
							<a href={`tel:${location.data.phoneNumber || phoneCT}`} class="bg-aac-yellow text-aac-dark px-6 py-3 rounded-xl font-black uppercase tracking-widest text-[11px] border-2 border-aac-dark shadow-[4px_4px_0px_0px_rgba(255,255,255,0.1)] hover:translate-y-[-2px] transition-all inline-flex items-center gap-2">
								<Icon name="Phone" size={16} />
								Call {location.data.phoneNumber || phoneCT}
							</a>
							<a href={`sms:${location.data.phoneNumber || phoneCT}`} class="bg-white/10 backdrop-blur-sm text-white px-6 py-3 rounded-xl font-black uppercase tracking-widest text-[11px] border border-white/20 hover:bg-white/20 transition-all inline-flex items-center gap-2">
								<Icon name="MessageSquare" size={16} />
								Text Us Photos
							</a>
						</div>
					</div>

					<div class="hidden lg:block">
						<div class="aspect-[4/3] rounded-[32px] overflow-hidden border-4 border-white/20 bg-zinc-800">
							<img
								src={webpSrc(heroImage.src)}
								srcset={projectSrcset(heroImage.src)}
								sizes="(max-width: 1024px) calc(100vw - 48px), 600px"
								alt={heroImage.alt}
								class="w-full h-full object-cover"
								width="800"
								height="600"
								loading="lazy"
							/>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- 3-Step Process Bar -->
		<ProcessBar />

		<!-- City Info Section -->
		{(location.data.neighborhoods || location.data.commonFoundationTypes) && (
			<section class="py-16 bg-zinc-50">
				<div class="max-w-7xl mx-auto px-6">
					<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
						{location.data.neighborhoods && location.data.neighborhoods.length > 0 && (
							<div class="bg-white p-8 rounded-2xl border-2 border-zinc-100">
								<p class="font-black text-lg mb-4 flex items-center gap-2">
									<Icon name="MapPin" size={20} class="text-aac-blue" />
									Neighborhoods We Serve
								</p>
								<ul class="space-y-2 text-zinc-600">
									{location.data.neighborhoods.map(neighborhood => (
										<li class="flex items-center gap-2">
											<Icon name="CheckCircle2" size={14} class="text-green-500" />
											{neighborhood}
										</li>
									))}
								</ul>
							</div>
						)}

						{location.data.commonFoundationTypes && location.data.commonFoundationTypes.length > 0 && (
							<div class="bg-white p-8 rounded-2xl border-2 border-zinc-100">
								<p class="font-black text-lg mb-4 flex items-center gap-2">
									<Icon name="Hammer" size={20} class="text-aac-blue" />
									Common Foundation Types
								</p>
								<ul class="space-y-2 text-zinc-600">
									{location.data.commonFoundationTypes.map(type => (
										<li class="flex items-center gap-2">
											<Icon name="CheckCircle2" size={14} class="text-green-500" />
											{type}
										</li>
									))}
								</ul>
							</div>
						)}

						{location.data.averageHomeAge && (
							<div class="bg-white p-8 rounded-2xl border-2 border-zinc-100">
								<p class="font-black text-lg mb-4 flex items-center gap-2">
									<Icon name="Clock" size={20} class="text-aac-blue" />
									Local Insights
								</p>
								<p class="text-zinc-600">
									<strong>Average Home Age:</strong> {location.data.averageHomeAge}
								</p>
								{location.data.population && (
									<p class="text-zinc-600 mt-2">
										<strong>Population:</strong> {location.data.population.toLocaleString()}
									</p>
								)}
							</div>
						)}
					</div>
				</div>
			</section>
		)}

		<!-- Main Content -->
		<section class="py-16 bg-white">
			<div class="max-w-4xl mx-auto px-6">
				<article class="prose prose-lg prose-zinc max-w-none prose-headings:font-black prose-headings:tracking-tight prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-4 prose-p:leading-relaxed prose-a:text-aac-blue prose-a:font-bold prose-a:no-underline hover:prose-a:underline prose-strong:text-aac-dark">
					<Content />

					{location.data.neighborhoods && location.data.neighborhoods.length > 0 && (
						<Fragment>
							<h2>Neighborhoods We Serve in {location.data.city}</h2>
							<p>
								We provide foundation repair services throughout {location.data.city}, including {
									location.data.neighborhoods.length === 1
										? location.data.neighborhoods[0]
										: location.data.neighborhoods.length === 2
											? `${location.data.neighborhoods[0]} and ${location.data.neighborhoods[1]}`
											: `${location.data.neighborhoods.slice(0, -1).join(', ')}, and ${location.data.neighborhoods[location.data.neighborhoods.length - 1]}`
								}. Whether your home is in a newer development or an older established neighborhood, our team knows the local soil conditions and foundation types common to each area.
							</p>
						</Fragment>
					)}

					<Fragment>
						<h2>Why {location.data.city} Homes Need Foundation Repair</h2>
						<p>
							Connecticut homes face unique foundation challenges due to the region's glacial till soils, harsh freeze-thaw cycles, and aging housing stock.
							{location.data.averageHomeAge && ` Many ${location.data.city} homes date to the ${location.data.averageHomeAge}, an era when concrete mixes and construction practices differed from today's standards.`}
							{' '}Seasonal temperature swings cause concrete to expand and contract, eventually forming cracks that allow water infiltration. Common signs include water in the basement after rain, white powder on basement walls (efflorescence), and a musty smell in the basement.
						</p>
						<p>
							Our {location.data.city} foundation repair services include <a href="/services/foundation-crack-injection">crack injection</a> ($800-$1,200 per crack), <a href="/services/carbon-fiber-stitches">carbon fiber staples</a> for structural reinforcement, <a href="/services/leaky-bulkhead-repair">bulkhead sealant repair</a>, and <a href="/services/sewer-well-conduit-line-repair">pipe penetration sealing</a> — all backed by a lifetime guarantee. Text us a photo for a free foundation inspection.
						</p>
					</Fragment>
				</article>
			</div>
		</section>

		<!-- Services in This City -->
		<section class="py-16 bg-zinc-50">
			<div class="max-w-7xl mx-auto px-6">
				<h2 class="text-3xl font-black tracking-tighter text-aac-dark mb-8 text-center">
					Services in {location.data.city}
				</h2>
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
					{services.map((service) => (
						<a href={`/services/${service.id.replace(/\.md$/, '')}`} class="group bg-white p-6 rounded-xl border-2 border-zinc-100 hover:border-aac-blue transition-all flex items-start gap-4">
							<div class="w-12 h-12 bg-aac-blue/5 text-aac-blue rounded-xl flex items-center justify-center shrink-0 group-hover:bg-aac-blue group-hover:text-white transition-colors">
								<Icon name={service.data.icon} size={24} />
							</div>
							<div>
								<h3 class="font-black group-hover:text-aac-blue transition-colors">
									{service.data.title}
								</h3>
								<p class="text-sm text-zinc-500 mt-1 line-clamp-2">
									{service.data.excerpt}
								</p>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- Pricing Section -->
		<section class="py-16 bg-white">
			<div class="max-w-4xl mx-auto px-6">
				<h2 class="text-3xl font-black tracking-tighter text-aac-dark mb-8 text-center">
					{location.data.city} Foundation Repair Costs
				</h2>
				<div class="grid sm:grid-cols-2 gap-4">
					<div class="p-6 rounded-xl border-2 border-zinc-100 flex items-center gap-4">
						<div class="w-10 h-10 bg-aac-blue/5 text-aac-blue rounded-lg flex items-center justify-center shrink-0">
							<Icon name="Hammer" size={20} />
						</div>
						<div>
							<p class="font-black text-aac-dark">Crack Repair</p>
							<p class="text-aac-blue font-bold">{crackRepairRange} per crack</p>
						</div>
					</div>
					<div class="p-6 rounded-xl border-2 border-zinc-100 flex items-center gap-4">
						<div class="w-10 h-10 bg-aac-blue/5 text-aac-blue rounded-lg flex items-center justify-center shrink-0">
							<Icon name="Droplets" size={20} />
						</div>
						<div>
							<p class="font-black text-aac-dark">Bulkhead Repair</p>
							<p class="text-aac-blue font-bold">{bulkheadRange}</p>
						</div>
					</div>
					<div class="p-6 rounded-xl border-2 border-zinc-100 flex items-center gap-4">
						<div class="w-10 h-10 bg-aac-blue/5 text-aac-blue rounded-lg flex items-center justify-center shrink-0">
							<Icon name="ShieldCheck" size={20} />
						</div>
						<div>
							<p class="font-black text-aac-dark">Carbon Fiber Stitches</p>
							<p class="text-aac-blue font-bold">{carbonFiberRange} per stitch</p>
						</div>
					</div>
					<div class="p-6 rounded-xl border-2 border-zinc-100 flex items-center gap-4">
						<div class="w-10 h-10 bg-aac-blue/5 text-aac-blue rounded-lg flex items-center justify-center shrink-0">
							<Icon name="Wrench" size={20} />
						</div>
						<div>
							<p class="font-black text-aac-dark">Pipe/Conduit Sealing</p>
							<p class="text-aac-blue font-bold">{sewerConduitRange}</p>
						</div>
					</div>
				</div>
				<p class="text-center text-sm text-zinc-500 mt-6">
					All prices are estimates. <a href="/services/free-foundation-consultations" class="text-aac-blue font-bold hover:underline">Get a free quote</a> for your specific situation.
				</p>
			</div>
		</section>

		<!-- FAQs -->
		{location.data.faqs && location.data.faqs.length > 0 && (
			<section class="py-16 bg-zinc-50">
				<div class="max-w-4xl mx-auto px-6">
					<h2 class="text-3xl font-black tracking-tighter text-aac-dark mb-8 text-center">
						Foundation Repair FAQs for {location.data.city}
					</h2>
					<div class="space-y-4">
						{location.data.faqs.map((faq) => (
							<details class="group bg-white rounded-xl overflow-hidden">
								<summary class="flex justify-between items-center p-6 cursor-pointer font-bold hover:text-aac-blue transition-colors list-none">
									{faq.question}
									<Icon name="ChevronRight" size={20} class="text-aac-blue rotate-90 group-open:rotate-270 transition-transform" />
								</summary>
								<div class="px-6 pb-6 text-zinc-600">
									{faq.answer}
								</div>
							</details>
						))}
					</div>
				</div>
			</section>
		)}

		<!-- Testimonial -->
		{testimonial && (
			<section class="py-16 bg-aac-blue text-white">
				<div class="max-w-4xl mx-auto px-6 text-center">
					<Icon name="Star" size={48} class="text-aac-yellow mx-auto mb-6" />
					<blockquote class="text-2xl lg:text-3xl font-bold mb-6 leading-relaxed">
						"{testimonial.quote}"
					</blockquote>
					<p class="font-black">
						— {testimonial.author}
						{testimonial.location && (
							<span class="font-normal text-white/90">, {testimonial.location}</span>
						)}
					</p>
				</div>
			</section>
		)}

		<!-- Featured Projects -->
		<ProjectCards
			projects={cityProjects}
			heading={`Featured Work in ${location.data.city}`}
		/>

		<!-- Foundation Guides -->
		{cityBlogPosts.length > 0 && (
			<section class="py-16 bg-white">
				<div class="max-w-7xl mx-auto px-6">
					<h2 class="text-2xl font-black tracking-tighter text-aac-dark mb-8">
						Foundation Guides for {location.data.city} Homeowners
					</h2>
					<div class="grid md:grid-cols-3 gap-6">
						{cityBlogPosts.map((post) => (
							<a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="group bg-zinc-50 rounded-2xl overflow-hidden border-2 border-zinc-100 hover:border-aac-blue transition-all">
								{post.data.heroImage && (
									<div class="aspect-video overflow-hidden">
										<img
											src={webpSrc(post.data.heroImage)}
											srcset={projectSrcset(post.data.heroImage)}
											sizes="(max-width: 640px) calc(100vw - 48px), (max-width: 1024px) 344px, 400px"
											alt={post.data.heroImageAlt || post.data.title}
											class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
											width="640"
											height="360"
											loading="lazy"
										/>
									</div>
								)}
								<div class="p-5">
									<h3 class="font-black text-sm group-hover:text-aac-blue transition-colors line-clamp-2">
										{post.data.title}
									</h3>
									<p class="text-zinc-500 text-xs mt-2 line-clamp-2">{post.data.excerpt}</p>
								</div>
							</a>
						))}
					</div>
				</div>
			</section>
		)}

		<!-- Nearby Cities -->
		{nearbyLocations.length > 0 && (
			<section class="py-16 bg-zinc-50">
				<div class="max-w-7xl mx-auto px-6">
					<h2 class="text-2xl font-black tracking-tighter text-aac-dark mb-8">
						We Also Serve Nearby Cities
					</h2>
					<div class="flex flex-wrap gap-4">
						{nearbyLocations.map(nearby => (
							<a
								href={`/connecticut/${nearby.id.replace(/\.md$/, '').replace(/^connecticut\//, '')}`}
								class="px-4 py-2 bg-white border-2 border-zinc-200 rounded-full font-bold text-zinc-700 hover:border-aac-blue hover:text-aac-blue transition-colors"
							>
								{nearby.data.city}, CT
							</a>
						))}
					</div>
				</div>
			</section>
		)}

		<!-- CTA Section -->
		<section class="py-16 bg-aac-dark text-white">
			<div class="max-w-4xl mx-auto px-6 text-center">
				<h2 class="text-3xl lg:text-4xl font-black tracking-tighter mb-6">
					Need Foundation Repair in {location.data.city}?
				</h2>
				<p class="text-lg text-zinc-300 mb-8">
					Get a free consultation from our local experts. We'll assess your foundation and provide an honest quote.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href={`tel:${location.data.phoneNumber || phoneCT}`} class="bg-aac-yellow text-aac-dark px-10 py-5 rounded-xl font-black uppercase tracking-widest text-sm hover:translate-y-[-2px] transition-all inline-flex items-center justify-center gap-2 border-2 border-aac-dark">
						<Icon name="Phone" size={20} />
						{location.data.phoneNumber || phoneCT}
					</a>
					<a href={`sms:${location.data.phoneNumber || phoneCT}`} class="bg-white/10 text-white px-10 py-5 rounded-xl font-black uppercase tracking-widest text-sm hover:bg-white/20 transition-all border border-white/20 inline-flex items-center justify-center gap-2">
						<Icon name="MessageSquare" size={20} />
						Text Photos
					</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
	<StickyCTA phone={location.data.phoneNumber || phoneCT} phoneHref={`tel:${location.data.phoneNumber || phoneCT}`} smsHref={`sms:${location.data.phoneNumber || phoneCT}`} reviewCount={reviewCountDisplay} />
</Layout>
