---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import LocationModal from '../../components/LocationModal.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/Icon.astro';
import { isPublished } from '../../utils/blog';
import { webpSrc, projectSrcset } from '../../utils/image';

const categoryLabels: Record<string, string> = {
	'guides': 'Guide',
	'case-studies': 'Case Study',
	'cost-guides': 'Cost Guide',
	'maintenance-tips': 'Tips',
	'news': 'News',
	'foundation-types': 'Foundation Types',
};

const serviceTypeLabels: Record<string, string> = {
	'crack-injection': 'Crack Injection',
	'wall-crack-repair': 'Wall Crack Repair',
	'bulkhead-repair': 'Bulkhead Repair',
	'carbon-fiber': 'Carbon Fiber',
	'sewer-conduit': 'Sewer & Conduit',
	'concrete-repair': 'Concrete Repair',
	'garage-floor': 'Garage Floor',
	'driveway': 'Driveway Repair',
	'patio': 'Patio Repair',
	'pool-deck': 'Pool Deck',
	'stairway': 'Stairway Repair',
	'walkway': 'Walkway Repair',
	'floor-crack': 'Floor Crack Repair',
	'fieldstone': 'Fieldstone Repair',
};

const allPosts = (await getCollection('blog', isPublished))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const allProjects = (await getCollection('projects', ({ data }) => data.published))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = allPosts.reduce((acc, post) => {
	acc[post.data.category] = (acc[post.data.category] || 0) + 1;
	return acc;
}, {} as Record<string, number>);

const totalPosts = allPosts.length;

function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	});
}

const breadcrumbItems = [
	{ label: 'Home', href: '/' },
	{ label: 'Updates' }
];

const description = "Expert articles, cost guides, and recent project case studies from Attack A Crack. Foundation repair insights for New England homeowners.";

const itemListSchema = {
	"@type": "ItemList",
	"name": "Foundation Repair Updates",
	"description": description,
	"numberOfItems": totalPosts,
	"itemListElement": allPosts.slice(0, 10).map((post, index) => ({
		"@type": "ListItem",
		"position": index + 1,
		"url": `https://www.attackacrack.com/blog/${post.id.replace(/\.md$/, '')}`,
		"name": post.data.title,
	})),
};

const ARTICLES_PER_PAGE = 6;
const articleTotalPages = Math.ceil(allPosts.length / ARTICLES_PER_PAGE);

const PROJECTS_PER_PAGE = 8;
const projectTotalPages = Math.ceil(allProjects.length / PROJECTS_PER_PAGE);
---

<Layout
	title="Foundation Repair Updates"
	description={description}
	pageType="hub"
	customSchema={itemListSchema}
	breadcrumbItems={breadcrumbItems}
>
	<LocationModal />
	<Navbar currentPage="updates" />

	<main class="pt-20 lg:pt-24">
		<!-- Hero Section -->
		<section class="py-20 lg:py-32 bg-white border-b-4 border-zinc-100">
			<div class="max-w-7xl mx-auto px-6">
				<Breadcrumbs items={breadcrumbItems} class="mb-8" />
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<div>
						<h1 class="text-6xl lg:text-8xl font-black tracking-tighter mb-8 leading-none">
							UP<br />
							<span class="text-aac-blue">DATES</span>
						</h1>
						<p class="text-xl text-zinc-500 max-w-lg">
							Expert articles, cost guides, and before-and-after project case studies from New England's foundation repair specialists.
						</p>
					</div>
					<div>
						<!-- Category Filter Pills -->
						<div class="flex flex-wrap gap-3" id="category-filters">
							<a href="/updates" class="px-4 py-2 rounded-full text-sm font-bold transition-colors bg-aac-dark text-white">
								All ({totalPosts})
							</a>
							{Object.entries(categories).map(([cat, count]) => (
								<a href={`/blog/category/${cat}`} class="px-4 py-2 bg-zinc-100 text-zinc-700 rounded-full text-sm font-bold hover:bg-aac-blue hover:text-white transition-colors">
									{categoryLabels[cat] || cat} ({count})
								</a>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Articles Grid -->
		<section class="py-24 bg-zinc-50">
			<div class="max-w-7xl mx-auto px-6">
				<div class="flex items-center justify-between mb-12">
					<h2 id="articles-heading" class="text-3xl font-black">Latest Articles</h2>
					<a href="/blog" class="inline-flex items-center gap-2 text-aac-blue font-black uppercase tracking-widest text-[10px] hover:gap-4 transition-all">
						View All Articles <Icon name="ArrowRight" size={14} />
					</a>
				</div>

				<div id="articles-grid" class="grid grid-cols-2 lg:grid-cols-3 gap-4 md:gap-8">
					{allPosts.map((post, i) => (
						<a
							href={`/blog/${post.id.replace(/\.md$/, '')}`}
							data-apage={Math.floor(i / ARTICLES_PER_PAGE) + 1}
							class="article-card group bg-white rounded-[32px] overflow-hidden border-2 border-zinc-100 hover:border-aac-blue transition-all"
							style={i >= ARTICLES_PER_PAGE ? 'display:none' : ''}
						>
							<div class="aspect-video overflow-hidden relative">
								<img
									src={webpSrc(post.data.heroImage || "/images/projects/marshfield-crack-injection-2025-06-before.jpg")}
									srcset={projectSrcset(post.data.heroImage || "/images/projects/marshfield-crack-injection-2025-06-before.jpg")}
									sizes="(max-width: 640px) calc(50vw - 32px), (max-width: 1024px) 344px, 380px"
									alt={post.data.heroImageAlt || post.data.title}
									class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
									width="640"
									height="360"
									loading={i < ARTICLES_PER_PAGE ? 'eager' : 'lazy'}
									fetchpriority={i === 0 ? 'high' : undefined}
								/>
								<div class="absolute top-4 left-4 bg-aac-dark/80 backdrop-blur-md text-white text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-lg border border-white/20">
									{categoryLabels[post.data.category] || 'Article'}
								</div>
							</div>
							<div class="p-8">
								<div class="flex items-center gap-4 mb-4">
									<span class="text-[10px] font-black uppercase tracking-widest text-aac-blue">
										Article
									</span>
									<span class="text-[10px] text-zinc-500 font-bold">
										{formatDate(post.data.publishDate)}
									</span>
								</div>
								<h3 class="text-xl font-black mb-3 leading-tight group-hover:text-aac-blue transition-colors">
									{post.data.title}
								</h3>
								<p class="text-zinc-500 text-sm leading-relaxed mb-4 line-clamp-3">
									{post.data.excerpt}
								</p>
								<span class="inline-flex items-center gap-2 text-aac-dark font-black uppercase tracking-widest text-[10px] group-hover:gap-4 transition-all">
									Read Article <Icon name="ArrowRight" size={14} />
								</span>
							</div>
						</a>
					))}
				</div>

				{articleTotalPages > 1 && (
					<nav id="articles-nav" class="flex items-center justify-center gap-2 mt-12" aria-label="Articles pagination" data-total={articleTotalPages}>
					</nav>
				)}
			</div>
		</section>

		<!-- Recent Projects Section -->
		{allProjects.length > 0 && (
			<section class="py-24 bg-white border-t-4 border-zinc-100">
				<div class="max-w-7xl mx-auto px-6">
					<div class="flex items-center justify-between mb-12">
						<div>
							<div class="inline-flex items-center gap-2 px-4 py-2 bg-aac-blue/5 text-aac-blue rounded-full text-[10px] font-black uppercase tracking-widest mb-4 border border-aac-blue/20">
								<Icon name="Hammer" size={14} /> Before & After
							</div>
							<h2 class="text-3xl lg:text-4xl font-black tracking-tighter text-aac-dark">
								Featured Projects
							</h2>
						</div>
						<a href="/projects" class="inline-flex items-center gap-2 text-aac-blue font-black uppercase tracking-widest text-[10px] hover:gap-4 transition-all">
							View All Projects <Icon name="ArrowRight" size={14} />
						</a>
					</div>

					<div id="updates-projects-grid" class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8">
						{allProjects.map((project, i) => (
							<a href={`/projects/${project.id.replace(/\.md$/, '')}`} data-ppage={Math.floor(i / PROJECTS_PER_PAGE) + 1} class="updates-project-card group bg-zinc-50 rounded-2xl overflow-hidden border-2 border-zinc-100 hover:border-aac-blue transition-all" style={i >= PROJECTS_PER_PAGE ? 'display:none' : ''}>
								<div class="aspect-video overflow-hidden relative">
									<img
										src={webpSrc(project.data.afterImage)}
										srcset={projectSrcset(project.data.afterImage)}
										sizes="(max-width: 640px) calc(50vw - 32px), (max-width: 1024px) 344px, 280px"
										alt={`${project.data.title} - After repair`}
										class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
										width="640"
										height="360"
										loading={i < PROJECTS_PER_PAGE ? 'eager' : 'lazy'}
										referrerpolicy="no-referrer"
									/>
									<div class="absolute top-3 left-3 bg-aac-dark/80 backdrop-blur-md text-white text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-lg border border-white/20">
										{serviceTypeLabels[project.data.serviceTypes[0]] || 'Project'}
									</div>
								</div>
								<div class="p-6">
									<p class="text-[10px] font-black uppercase tracking-widest text-aac-blue mb-2">
										{project.data.city}, {project.data.state}
									</p>
									<h3 class="text-lg font-black mb-2 leading-tight group-hover:text-aac-blue transition-colors">
										{project.data.title}
									</h3>
									<p class="text-zinc-500 text-sm line-clamp-2">
										{project.data.summary}
									</p>
								</div>
							</a>
						))}
					</div>

					{projectTotalPages > 1 && (
						<nav id="pp-nav" class="flex items-center justify-center gap-2 mt-8" aria-label="Projects pagination" data-total={projectTotalPages}>
						</nav>
					)}
				</div>
			</section>
		)}

		<!-- CTA Section -->
		<section class="py-16 bg-aac-yellow">
			<div class="max-w-4xl mx-auto px-6 text-center">
				<h2 class="text-3xl lg:text-4xl font-black text-aac-dark mb-6">
					Have a Foundation Question?
				</h2>
				<p class="text-lg text-aac-dark/70 mb-8">
					Get a free assessment from our experts.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<button class="open-modal bg-aac-dark text-white px-8 py-4 rounded-xl font-black uppercase tracking-widest text-sm hover:translate-y-[-2px] transition-all inline-flex items-center justify-center gap-2">
						<Icon name="MessageSquare" size={20} />
						Text Us Photos
					</button>
					<a href="/services/free-foundation-consultations" class="bg-white text-aac-dark px-8 py-4 rounded-xl font-black uppercase tracking-widest text-sm hover:translate-y-[-2px] transition-all inline-flex items-center justify-center gap-2 border-2 border-aac-dark">
						Free Consultation
					</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />

	<script>
		// Shared URL param helpers
		function getParam(key: string): number {
			return parseInt(new URLSearchParams(location.search).get(key) || '1');
		}
		function setParams(updates: Record<string, number>) {
			const params = new URLSearchParams(location.search);
			for (const [k, v] of Object.entries(updates)) {
				v === 1 ? params.delete(k) : params.set(k, String(v));
			}
			const qs = params.toString();
			history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
		}

		function getPageNumbers(current: number, last: number): (number | '...')[] {
			if (last <= 5) return Array.from({ length: last }, (_, i) => i + 1);
			const pages: (number | '...')[] = [1];
			if (current > 3) pages.push('...');
			for (let i = Math.max(2, current - 1); i <= Math.min(last - 1, current + 1); i++) pages.push(i);
			if (current < last - 2) pages.push('...');
			pages.push(last);
			return pages;
		}

		// --- Articles pagination ---
		const articleCards = document.querySelectorAll('.article-card');
		const articlesNav = document.getElementById('articles-nav');
		const articleTotalPages = articlesNav ? parseInt(articlesNav.dataset.total || '1') : 1;
		let articlePage = Math.min(Math.max(1, getParam('articles')), articleTotalPages);

		function renderArticlesPagination() {
			if (!articlesNav) return;
			const pages = getPageNumbers(articlePage, articleTotalPages);
			const prevDisabled = articlePage === 1;
			const nextDisabled = articlePage === articleTotalPages;
			articlesNav.innerHTML = `
				<button id="a-prev" class="px-3 py-2 rounded-lg border-2 border-zinc-200 text-zinc-500 hover:border-aac-blue hover:text-aac-blue transition-all disabled:opacity-30 disabled:cursor-not-allowed" ${prevDisabled ? 'disabled' : ''} aria-label="Previous articles page">&larr;</button>
				${pages.map(p => p === '...'
					? '<span class="px-3 py-2 text-zinc-400">...</span>'
					: `<button data-agoto="${p}" class="a-btn w-10 h-10 rounded-lg border-2 text-sm font-black transition-all ${p === articlePage ? 'border-aac-blue bg-aac-blue text-white' : 'border-zinc-200 text-zinc-500 hover:border-aac-blue hover:text-aac-blue'}">${p}</button>`
				).join('')}
				<button id="a-next" class="px-3 py-2 rounded-lg border-2 border-zinc-200 text-zinc-500 hover:border-aac-blue hover:text-aac-blue transition-all disabled:opacity-30 disabled:cursor-not-allowed" ${nextDisabled ? 'disabled' : ''} aria-label="Next articles page">&rarr;</button>
			`;
			articlesNav.querySelectorAll('.a-btn').forEach(btn => {
				btn.addEventListener('click', () => showArticlePage(parseInt((btn as HTMLElement).dataset.agoto || '1'), true));
			});
			document.getElementById('a-prev')?.addEventListener('click', () => { if (articlePage > 1) showArticlePage(articlePage - 1, true); });
			document.getElementById('a-next')?.addEventListener('click', () => { if (articlePage < articleTotalPages) showArticlePage(articlePage + 1, true); });
		}

		function showArticlePage(page: number, scroll: boolean) {
			articlePage = page;
			setParams({ articles: page });
			const heading = document.getElementById('articles-heading');
			if (heading) heading.textContent = page === 1 ? 'Latest Articles' : `Articles — Page ${page}`;
			articleCards.forEach(card => {
				const p = parseInt((card as HTMLElement).dataset.apage || '1');
				(card as HTMLElement).style.display = p === page ? '' : 'none';
			});
			renderArticlesPagination();
			if (scroll) {
				document.getElementById('articles-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		}

		// --- Projects pagination ---
		const projectCards = document.querySelectorAll('.updates-project-card');
		const ppNav = document.getElementById('pp-nav');
		const projectTotalPages = ppNav ? parseInt(ppNav.dataset.total || '1') : 1;
		let projectPage = Math.min(Math.max(1, getParam('projects')), projectTotalPages);

		function renderProjectsPagination() {
			if (!ppNav) return;
			const pages = getPageNumbers(projectPage, projectTotalPages);
			const prevDisabled = projectPage === 1;
			const nextDisabled = projectPage === projectTotalPages;
			ppNav.innerHTML = `
				<button id="pp-prev" class="px-3 py-2 rounded-lg border-2 border-zinc-200 text-zinc-500 hover:border-aac-blue hover:text-aac-blue transition-all disabled:opacity-30 disabled:cursor-not-allowed" ${prevDisabled ? 'disabled' : ''} aria-label="Previous projects page">&larr;</button>
				${pages.map(p => p === '...'
					? '<span class="px-3 py-2 text-zinc-400">...</span>'
					: `<button data-ppgoto="${p}" class="pp-btn w-10 h-10 rounded-lg border-2 text-sm font-black transition-all ${p === projectPage ? 'border-aac-blue bg-aac-blue text-white' : 'border-zinc-200 text-zinc-500 hover:border-aac-blue hover:text-aac-blue'}">${p}</button>`
				).join('')}
				<button id="pp-next" class="px-3 py-2 rounded-lg border-2 border-zinc-200 text-zinc-500 hover:border-aac-blue hover:text-aac-blue transition-all disabled:opacity-30 disabled:cursor-not-allowed" ${nextDisabled ? 'disabled' : ''} aria-label="Next projects page">&rarr;</button>
			`;
			ppNav.querySelectorAll('.pp-btn').forEach(btn => {
				btn.addEventListener('click', () => showProjectPage(parseInt((btn as HTMLElement).dataset.ppgoto || '1'), true));
			});
			document.getElementById('pp-prev')?.addEventListener('click', () => { if (projectPage > 1) showProjectPage(projectPage - 1, true); });
			document.getElementById('pp-next')?.addEventListener('click', () => { if (projectPage < projectTotalPages) showProjectPage(projectPage + 1, true); });
		}

		function showProjectPage(page: number, scroll: boolean) {
			projectPage = page;
			setParams({ projects: page });
			projectCards.forEach(card => {
				const p = parseInt((card as HTMLElement).dataset.ppage || '1');
				(card as HTMLElement).style.display = p === page ? '' : 'none';
			});
			renderProjectsPagination();
			if (scroll) {
				document.getElementById('updates-projects-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		}

		// Initialize both pagers from URL params (no scroll)
		showArticlePage(articlePage, false);
		showProjectPage(projectPage, false);
	</script>
</Layout>
