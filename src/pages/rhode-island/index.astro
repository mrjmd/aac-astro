---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import LocationModal from '../../components/LocationModal.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/Icon.astro';
import { aggregateRatingSchema } from '../../utils/reviews';
import { phoneMA, phoneMAHref } from '../../utils/contact';
import { RI_REGIONS } from '../../utils/regions';
import { webpSrc, projectSrcset } from '../../utils/image';
import TrustBar from '../../components/TrustBar.astro';

// Get all RI location pages
const riLocations = (await getCollection('locations'))
  .filter(loc => loc.data.stateAbbr === 'RI')
  .sort((a, b) => a.data.city.localeCompare(b.data.city));

// Get services for listing
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Rhode Island' }
];

// LocalBusiness schema for RI
const riSchema = {
  "@type": "HomeAndConstructionBusiness",
  "name": "Attack A Crack Foundation Repair - Rhode Island",
  "image": "https://www.attackacrack.com/images/logo.jpg",
  "@id": "https://www.attackacrack.com/rhode-island#organization",
  "url": "https://www.attackacrack.com/rhode-island",
  "telephone": phoneMA,
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "addressRegion": "RI",
    "addressCountry": "US"
  },
  "areaServed": {
    "@type": "State",
    "name": "Rhode Island"
  },
  "aggregateRating": aggregateRatingSchema,
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
    "opens": "07:00",
    "closes": "19:00"
  }
};
---

<Layout
  title="Foundation Repair in Rhode Island"
  description={`Expert foundation crack repair across Rhode Island. Family-owned with 20+ years experience. Concrete repair available. Call ${phoneMA}.`}
  customSchema={riSchema}
  breadcrumbItems={breadcrumbItems}
>
	<LocationModal />
	<Navbar />

	<main class="pt-20 lg:pt-24">
		<!-- Hero Section -->
		<section class="py-20 lg:py-32 bg-aac-dark text-white relative overflow-hidden">
			<div class="absolute top-0 right-0 w-1/2 h-full bg-aac-blue/10 skew-x-12 translate-x-1/2"></div>
			<div class="max-w-7xl mx-auto px-6 relative z-10">
				<Breadcrumbs items={breadcrumbItems} class="mb-8" variant="dark" />

				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<div>
						<div class="inline-flex items-center gap-2 px-4 py-2 bg-aac-yellow/20 text-aac-yellow rounded-full text-[10px] font-black uppercase tracking-widest mb-6 border border-aac-yellow/30">
							<Icon name="MapPin" size={14} /> Rhode Island
						</div>
						<h1 class="text-5xl lg:text-7xl font-black tracking-tighter mb-6 leading-none">
							Foundation Repair in <span class="text-aac-blue">Rhode Island</span>
						</h1>
						<p class="text-xl text-zinc-300 mb-8">
							Expert foundation crack repair from Providence to Newport. We specialize in crack injection, carbon fiber staples, and bulkhead sealant repair — plus concrete repair for driveways, patios, and pool decks. Rhode Island's coastal water table, salt air, and clay soils create unique foundation challenges we solve with a lifetime guarantee.
						</p>

						<div class="flex flex-wrap gap-4 mb-8">
							<div class="flex items-center gap-2 text-aac-yellow">
								<Icon name="Star" size={20} />
								<span class="font-bold">5-Star Reviews</span>
							</div>
							<div class="flex items-center gap-2 text-white">
								<Icon name="ShieldCheck" size={20} />
								<span class="font-bold">Lifetime Guarantee</span>
							</div>
							<div class="flex items-center gap-2 text-blue-400">
								<Icon name="Wrench" size={20} />
								<span class="font-bold">+ Resurfacing</span>
							</div>
						</div>

						<div class="flex flex-wrap gap-4">
							<a href={phoneMAHref} class="bg-aac-yellow text-aac-dark px-8 py-4 rounded-xl font-black uppercase tracking-widest text-[11px] border-2 border-aac-dark shadow-[4px_4px_0px_0px_rgba(255,255,255,0.1)] hover:translate-y-[-2px] transition-all inline-flex items-center gap-2">
								<Icon name="Phone" size={16} />
								Call {phoneMA}
							</a>
							<a href={`sms:${phoneMA}`} class="bg-white/10 backdrop-blur-sm text-white px-8 py-4 rounded-xl font-black uppercase tracking-widest text-[11px] border border-white/20 hover:bg-white/20 transition-all inline-flex items-center gap-2">
								<Icon name="MessageSquare" size={16} />
								Text Us Photos
							</a>
						</div>
					</div>

					<div class="relative hidden lg:block">
						<div class="aspect-square rounded-[32px] overflow-hidden border-4 border-white/20 bg-zinc-800">
							<img
								src={webpSrc("/images/projects/rumford-crack-injection-2025-08-before.jpg")}
								srcset={projectSrcset("/images/projects/rumford-crack-injection-2025-08-before.jpg")}
								sizes="(max-width: 1024px) calc(100vw - 48px), 600px"
								alt="Foundation crack repair in Rhode Island"
								class="w-full h-full object-cover"
								width="800"
								height="600"
								loading="lazy"
							/>
						</div>
						<div class="absolute -bottom-6 -right-6 bg-aac-blue p-6 rounded-2xl shadow-xl text-white">
							<div class="flex items-center gap-4">
								<Icon name="Wrench" size={32} />
								<div>
									<p class="text-lg font-black">RI Service</p>
									<p class="text-sm text-white/90">+ Concrete Resurfacing</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Concrete Resurfacing Banner -->
		<section class="py-8 bg-aac-blue text-white">
			<div class="max-w-7xl mx-auto px-6">
				<div class="flex flex-col md:flex-row items-center justify-between gap-6">
					<div class="flex items-center gap-4">
						<div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center">
							<Icon name="Wrench" size={24} />
						</div>
						<div>
							<p class="font-black text-lg">Concrete Resurfacing Available</p>
							<p class="text-white">Driveways, patios, pool decks, walkways, stairs & garage floors</p>
						</div>
					</div>
					<a href="/concrete-repair" class="bg-white text-aac-blue px-6 py-3 rounded-xl font-black uppercase tracking-widest text-[11px] hover:bg-aac-yellow hover:text-aac-dark transition-colors inline-flex items-center gap-2">
						Concrete Repair Services <Icon name="ArrowRight" size={14} />
					</a>
				</div>
			</div>
		</section>

		<!-- Trust Badges -->
		<TrustBar pathname={Astro.url.pathname} />

		<!-- Services We Offer -->
		<section class="py-24 bg-white">
			<div class="max-w-7xl mx-auto px-6">
				<div class="text-center mb-16">
					<h2 class="text-4xl lg:text-5xl font-black tracking-tighter text-aac-dark">
						Foundation Repair Services
					</h2>
					<p class="text-lg text-zinc-500 mt-4 max-w-2xl mx-auto">
						Foundation crack injection, carbon fiber staples, bulkhead sealant repair, and free foundation inspections for Rhode Island homes.
					</p>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
					{services.map((service) => (
						<a href={`/services/${service.id.replace(/\.md$/, '')}`} class="group p-8 rounded-2xl border-2 border-zinc-100 hover:border-aac-blue transition-all">
							<div class="w-14 h-14 bg-aac-blue/5 text-aac-blue rounded-xl flex items-center justify-center mb-6 group-hover:bg-aac-blue group-hover:text-white transition-colors">
								<Icon name={service.data.icon} size={28} />
							</div>
							<h3 class="text-xl font-black mb-3 group-hover:text-aac-blue transition-colors">
								{service.data.title}
							</h3>
							<p class="text-zinc-600 text-sm leading-relaxed">
								{service.data.excerpt}
							</p>
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- Areas We Serve -->
		<section class="py-24 bg-zinc-50">
			<div class="max-w-7xl mx-auto px-6">
				<div class="text-center mb-16">
					<h2 class="text-4xl font-black tracking-tighter text-aac-dark">
						Areas We Serve in Rhode Island
					</h2>
					<p class="text-lg text-zinc-500 mt-4">
						Foundation repair and concrete repair throughout Rhode Island.
					</p>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
					{Object.entries(RI_REGIONS).map(([region, cities]) => (
						<div class="bg-white p-8 rounded-2xl border-2 border-zinc-100">
							<h3 class="text-xl font-black mb-6 text-aac-dark">{region}</h3>
							<ul class="space-y-1">
								{cities.map(city => {
									const hasPage = riLocations.some(loc => loc.data.city === city);
									return hasPage ? (
										<li>
											<a href={`/rhode-island/${city.toLowerCase().replace(/\s+/g, '-')}`} class="flex items-center gap-2 py-2 text-aac-blue hover:underline font-medium">
												<Icon name="MapPin" size={14} />
												{city}
											</a>
										</li>
									) : (
										<li class="flex items-center gap-2 text-zinc-600">
											<Icon name="MapPin" size={14} class="text-zinc-500" />
											{city}
										</li>
									);
								})}
							</ul>
						</div>
					))}
				</div>

				<p class="text-center text-zinc-500 mt-12">
					Don't see your city? We serve all of Rhode Island! <a href={phoneMAHref} class="text-aac-blue font-bold hover:underline">Call {phoneMA}</a>
				</p>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-24 bg-aac-dark text-white">
			<div class="max-w-4xl mx-auto px-6 text-center">
				<h2 class="text-4xl lg:text-5xl font-black tracking-tighter mb-6">
					Get Your Free <span class="text-aac-yellow">RI Quote</span>
				</h2>
				<p class="text-xl text-zinc-300 mb-10">
					Foundation repair or concrete repair — text us photos for a quick assessment, completely free.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href={phoneMAHref} class="bg-aac-yellow text-aac-dark px-12 py-6 rounded-2xl font-black text-lg uppercase tracking-widest hover:translate-y-[-4px] transition-all shadow-[8px_8px_0px_0px_rgba(255,255,255,0.1)] border-4 border-white inline-flex items-center justify-center gap-3">
						<Icon name="Phone" size={24} />
						{phoneMA}
					</a>
					<a href={`sms:${phoneMA}`} class="bg-white/10 text-white px-12 py-6 rounded-2xl font-black text-lg uppercase tracking-widest hover:bg-white/20 transition-all border border-white/20 inline-flex items-center justify-center gap-3">
						<Icon name="MessageSquare" size={24} />
						Text Photos
					</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
