---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import LocationModal from '../../components/LocationModal.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/Icon.astro';
import { phoneCT, phoneCTHref, phoneMA, phoneMAHref } from '../../utils/contact';
import { webpSrc, projectSrcset } from '../../utils/image';

const allProjects = (await getCollection('projects', ({ data }) => data.published))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const PROJECTS_PER_PAGE = 12;
const totalPages = Math.ceil(allProjects.length / PROJECTS_PER_PAGE);

const serviceTypeLabels: Record<string, string> = {
	'crack-injection': 'Crack Injection',
	'wall-crack-repair': 'Wall Crack Repair',
	'bulkhead-repair': 'Bulkhead Repair',
	'carbon-fiber': 'Carbon Fiber',
	'sewer-conduit': 'Sewer & Conduit',
	'concrete-repair': 'Concrete Repair',
	'garage-floor': 'Garage Floor',
	'driveway': 'Driveway Repair',
	'patio': 'Patio Repair',
	'pool-deck': 'Pool Deck',
	'stairway': 'Stairway Repair',
	'walkway': 'Walkway Repair',
	'floor-crack': 'Floor Crack Repair',
	'fieldstone': 'Fieldstone Repair',
};

const stateLabels: Record<string, string> = {
	CT: 'Connecticut',
	MA: 'Massachusetts',
	RI: 'Rhode Island',
	NH: 'New Hampshire',
	ME: 'Maine',
};

const breadcrumbItems = [
	{ label: 'Home', href: '/' },
	{ label: 'Featured Projects' }
];

function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
	});
}

// ItemList schema for the hub page
const itemListSchema = {
	"@type": "ItemList",
	"name": "Featured Foundation Repair Projects",
	"description": "Highlights from thousands of foundation repairs across New England. Browse featured before and after project photos.",
	"numberOfItems": allProjects.length,
	"itemListElement": allProjects.map((project, index) => ({
		"@type": "ListItem",
		"position": index + 1,
		"url": `https://www.attackacrack.com/projects/${project.id.replace(/\.md$/, '')}`,
		"name": project.data.title,
	})),
};
---

<Layout
	title="Featured Foundation Repair Projects"
	description="Highlights from thousands of foundation repairs across New England. Browse featured before and after project photos with our lifetime guarantee."
	pageType="hub"
	customSchema={itemListSchema}
	breadcrumbItems={breadcrumbItems}
>
	<LocationModal />
	<Navbar />

	<main class="pt-20 lg:pt-24">
		<!-- Hero Section -->
		<section class="py-20 lg:py-32 bg-white border-b-4 border-zinc-100">
			<div class="max-w-7xl mx-auto px-6">
				<Breadcrumbs items={breadcrumbItems} class="mb-8" />
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<div>
						<h1 class="text-6xl lg:text-8xl font-black tracking-tighter mb-8 leading-none">
							FEATURED<br />
							<span class="text-aac-blue">PROJECTS.</span>
						</h1>
						<p class="text-xl text-zinc-500 max-w-lg">
							Highlights from thousands of jobs over 20+ years. Every project backed by our lifetime guarantee.
						</p>
					</div>
					<div class="text-right">
						<div class="inline-flex items-center gap-3 px-6 py-4 bg-aac-blue/5 text-aac-blue rounded-2xl border border-aac-blue/20">
							<Icon name="CheckCircle2" size={24} />
							<div class="text-left">
								<p class="text-3xl font-black">{allProjects.length}+</p>
								<p class="text-sm font-bold uppercase tracking-widest">Featured Projects</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Projects Grid -->
		<section class="py-24 bg-zinc-50">
			<div class="max-w-7xl mx-auto px-6">
				{allProjects.length > 0 ? (
				<>
					<div id="projects-grid" class="grid grid-cols-2 lg:grid-cols-3 gap-4 md:gap-8">
						{allProjects.map((project, i) => (
							<a href={`/projects/${project.id.replace(/\.md$/, '')}`} data-page={Math.floor(i / PROJECTS_PER_PAGE) + 1} class="project-card group bg-white rounded-[32px] overflow-hidden border-2 border-zinc-100 hover:border-aac-blue transition-all" style={i >= PROJECTS_PER_PAGE ? 'display:none' : ''}>
								<div class="aspect-video overflow-hidden relative">
									<img
										src={webpSrc(project.data.afterImage)}
										srcset={projectSrcset(project.data.afterImage)}
										sizes="(max-width: 640px) calc(50vw - 32px), (max-width: 1024px) 344px, 380px"
										alt={`${project.data.title} - After repair`}
										class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
										width="640"
										height="360"
										loading={i < PROJECTS_PER_PAGE ? 'eager' : 'lazy'}
										fetchpriority={i === 0 ? 'high' : undefined}
									/>
									<div class="absolute top-4 left-4 bg-aac-dark/80 backdrop-blur-md text-white text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-lg border border-white/20">
										{serviceTypeLabels[project.data.serviceTypes[0]]}
									</div>
								</div>
								<div class="p-8">
									<div class="flex items-center gap-4 mb-4">
										<span class="text-[10px] font-black uppercase tracking-widest text-aac-blue">
											{project.data.city}, {project.data.state}
										</span>
										<span class="text-[10px] text-zinc-500 font-bold">
											{formatDate(project.data.date)}
										</span>
									</div>
									<h2 class="text-xl font-black mb-3 leading-tight group-hover:text-aac-blue transition-colors">
										{project.data.title}
									</h2>
									<p class="text-zinc-500 text-sm leading-relaxed line-clamp-3">
										{project.data.summary}
									</p>
									<span class="inline-flex items-center gap-2 text-aac-dark font-black uppercase tracking-widest text-[10px] mt-4 group-hover:gap-4 transition-all">
										View Project <Icon name="ArrowRight" size={14} />
									</span>
								</div>
							</a>
						))}
					</div>

					{totalPages > 1 && (
						<nav id="proj-nav" class="flex items-center justify-center gap-2 mt-12" aria-label="Projects pagination" data-total={totalPages}>
						</nav>
					)}
				</>
				) : (
					<div class="text-center py-16">
						<div class="w-16 h-16 bg-aac-blue/5 text-aac-blue rounded-full flex items-center justify-center mx-auto mb-6">
							<Icon name="Hammer" size={32} />
						</div>
						<h2 class="text-2xl font-black mb-4">Projects Coming Soon</h2>
						<p class="text-zinc-500 text-lg max-w-md mx-auto">
							We're documenting our recent work. Check back soon for before and after photos from jobs across New England.
						</p>
					</div>
				)}
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-16 lg:py-24 bg-aac-dark text-white">
			<div class="max-w-7xl mx-auto px-6 text-center">
				<h2 class="text-4xl lg:text-5xl font-black tracking-tighter mb-6">
					Ready to Fix Your <span class="text-aac-yellow">Foundation?</span>
				</h2>
				<p class="text-xl text-zinc-300 max-w-2xl mx-auto mb-10">
					Get a free consultation with our experts. We'll assess your foundation and provide an honest quote — no pressure, just honest advice.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<button class="open-modal bg-aac-yellow text-aac-dark px-10 py-5 rounded-xl font-black uppercase tracking-widest text-sm hover:translate-y-[-2px] transition-all shadow-[4px_4px_0px_0px_rgba(255,255,255,0.1)] border-2 border-aac-dark inline-flex items-center justify-center gap-2">
						<Icon name="MessageSquare" size={20} />
						Text Us Photos
					</button>
					<a href={phoneCTHref} class="bg-white/10 text-white px-10 py-5 rounded-xl font-black uppercase tracking-widest text-sm hover:bg-white/20 transition-all border border-white/20 inline-flex items-center justify-center gap-2">
						<Icon name="Phone" size={20} />
						CT: {phoneCT}
					</a>
					<a href={phoneMAHref} class="bg-aac-blue text-white px-10 py-5 rounded-xl font-black uppercase tracking-widest text-sm hover:translate-y-[-2px] transition-all border-2 border-aac-dark shadow-[4px_4px_0px_0px_rgba(255,255,255,0.1)] inline-flex items-center justify-center gap-2">
						<Icon name="Phone" size={20} />
						MA: {phoneMA}
					</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />

	<script>
		const cards = document.querySelectorAll('.project-card');
		const nav = document.getElementById('proj-nav');
		const totalPages = nav ? parseInt(nav.dataset.total || '1') : 1;

		function getParam(key: string): number {
			return parseInt(new URLSearchParams(location.search).get(key) || '1');
		}
		function setParam(key: string, value: number) {
			const params = new URLSearchParams(location.search);
			value === 1 ? params.delete(key) : params.set(key, String(value));
			const qs = params.toString();
			history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
		}

		const initPage = Math.min(Math.max(1, getParam('page')), totalPages);
		let currentPage = initPage;

		function getPageNumbers(current: number, last: number): (number | '...')[] {
			if (last <= 5) return Array.from({ length: last }, (_, i) => i + 1);
			const pages: (number | '...')[] = [1];
			if (current > 3) pages.push('...');
			for (let i = Math.max(2, current - 1); i <= Math.min(last - 1, current + 1); i++) pages.push(i);
			if (current < last - 2) pages.push('...');
			pages.push(last);
			return pages;
		}

		function renderPagination() {
			if (!nav) return;
			const pages = getPageNumbers(currentPage, totalPages);
			const prevDisabled = currentPage === 1;
			const nextDisabled = currentPage === totalPages;
			nav.innerHTML = `
				<button id="prev-page" class="px-3 py-2 rounded-lg border-2 border-zinc-200 text-zinc-500 hover:border-aac-blue hover:text-aac-blue transition-all disabled:opacity-30 disabled:cursor-not-allowed" ${prevDisabled ? 'disabled' : ''} aria-label="Previous page">&larr;</button>
				${pages.map(p => p === '...'
					? '<span class="px-3 py-2 text-zinc-400">...</span>'
					: `<button data-goto="${p}" class="page-btn w-10 h-10 rounded-lg border-2 text-sm font-black transition-all ${p === currentPage ? 'border-aac-blue bg-aac-blue text-white' : 'border-zinc-200 text-zinc-500 hover:border-aac-blue hover:text-aac-blue'}">${p}</button>`
				).join('')}
				<button id="next-page" class="px-3 py-2 rounded-lg border-2 border-zinc-200 text-zinc-500 hover:border-aac-blue hover:text-aac-blue transition-all disabled:opacity-30 disabled:cursor-not-allowed" ${nextDisabled ? 'disabled' : ''} aria-label="Next page">&rarr;</button>
			`;
			nav.querySelectorAll('.page-btn').forEach(btn => {
				btn.addEventListener('click', () => showPage(parseInt((btn as HTMLElement).dataset.goto || '1'), true));
			});
			document.getElementById('prev-page')?.addEventListener('click', () => { if (currentPage > 1) showPage(currentPage - 1, true); });
			document.getElementById('next-page')?.addEventListener('click', () => { if (currentPage < totalPages) showPage(currentPage + 1, true); });
		}

		function showPage(page: number, scroll: boolean) {
			currentPage = page;
			setParam('page', page);
			cards.forEach(card => {
				const cardPage = parseInt((card as HTMLElement).dataset.page || '1');
				(card as HTMLElement).style.display = cardPage === page ? '' : 'none';
			});
			renderPagination();
			if (scroll) {
				document.getElementById('projects-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		}

		showPage(initPage, false);
	</script>
</Layout>
