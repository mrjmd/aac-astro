---
// QR code page for printing — generates QR dynamically based on current domain
// Usage: /partners/qr?ref=ed (defaults to ref=ed if omitted)
import '../../styles/global.css';
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Partner QR Code | Attack A Crack</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <style>
    @media print {
      body { background: white !important; }
      .no-print { display: none !important; }
    }
    #qr-container {
      display: flex;
      justify-content: center;
    }
    #qr-container svg {
      width: 280px;
      height: 280px;
    }
  </style>
</head>
<body class="min-h-screen bg-white flex items-center justify-center p-8">
  <div class="text-center max-w-sm">
    <div id="logos" class="flex items-center justify-center gap-4 mb-8">
      <img src="/images/logo.webp" alt="Attack A Crack" class="h-20" />
    </div>

    <div id="qr-container" class="mx-auto mb-6"></div>

    <p class="text-xl font-bold text-aac-dark mb-2">Scan to Partner with Us</p>
    <p id="referrer-name" class="text-sm text-gray-500"></p>

    <button onclick="window.print()" class="no-print mt-8 bg-aac-blue text-white font-bold py-3 px-8 rounded-lg hover:brightness-90 transition">
      Print This Page
    </button>
  </div>

  <script>
    import qrcode from 'qrcode-generator';

    const REFERRERS: Record<string, string> = {
      ed: 'Edward Crowell',
    };

    const PARTNER_LOGOS: Record<string, string> = {
      exit: '/images/partners/exit.webp',
    };

    const params = new URLSearchParams(window.location.search);
    const ref = params.get('ref') || 'ed';
    const partner = params.get('partner');

    // Add partner logo if specified
    if (partner && PARTNER_LOGOS[partner]) {
      const logos = document.getElementById('logos')!;
      const img = document.createElement('img');
      img.src = PARTNER_LOGOS[partner];
      img.alt = partner;
      img.className = 'h-20';
      logos.appendChild(img);
    }

    // Build capture URL — pass partner param through too
    const captureParams = new URLSearchParams({ ref });
    if (partner) captureParams.set('partner', partner);
    const captureUrl = `${window.location.origin}/partners/capture?${captureParams}`;

    // Generate QR code
    const qr = qrcode(0, 'M');
    qr.addData(captureUrl);
    qr.make();

    const container = document.getElementById('qr-container')!;
    container.innerHTML = qr.createSvgTag({ cellSize: 7, margin: 0 });

    // Show referrer name and URL
    const name = REFERRERS[ref] || ref;
    document.getElementById('referrer-name')!.textContent = name;
  </script>
</body>
</html>
