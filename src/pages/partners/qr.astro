---
// QR code page for printing — scan leads to /partners/capture?ref=ed
// To add more referrers: generate a new QR code SVG and add a block below
import '../../styles/global.css';
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Partner QR Code | Attack A Crack</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <style>
    @media print {
      body { background: white !important; }
      .no-print { display: none !important; }
    }
  </style>
</head>
<body class="min-h-screen bg-white flex items-center justify-center p-8">
  <div class="text-center max-w-sm">
