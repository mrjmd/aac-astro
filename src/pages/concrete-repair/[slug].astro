---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import LocationModal from '../../components/LocationModal.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/Icon.astro';
import ProjectCards from '../../components/ProjectCards.astro';
import { getByService as getProjectsByService, SERVICE_SLUG_MAP } from '../../utils/projects';
import { getBlogForService } from '../../utils/blog-linking';
import { phoneMA, phoneMAHref } from '../../utils/contact';
import { aggregateRatingSchema } from '../../utils/reviews';
import { webpSrc, projectSrcset } from '../../utils/image';

export async function getStaticPaths() {
  const services = await getCollection('concrete-repair');
  return services.map((service) => ({
    params: { slug: service.id.replace(/\.md$/, '') },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

// Get matching projects for this specific concrete repair type
const serviceSlug = service.id.replace(/\.md$/, '');
const projectServiceType = SERVICE_SLUG_MAP[serviceSlug] || 'concrete-repair';
const concreteProjects = await getProjectsByService(projectServiceType, 3);

// Get related blog posts for this concrete repair type
const relatedBlogPosts = await getBlogForService(serviceSlug, 4);

// Get all concrete repair services for related section
const allServices = await getCollection('concrete-repair');
const relatedServices = service.data.relatedServices
  ? allServices.filter(s => service.data.relatedServices?.includes(s.id.replace(/\.md$/, '')))
  : allServices.filter(s => s.id !== service.id).slice(0, 3);

// Get MA locations for reverse linking (concrete repair is MA-only)
const allLocations = await getCollection('locations');
const maLocations = allLocations.filter(l => l.data.stateAbbr === 'MA').slice(0, 8);

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Concrete Repair', href: '/concrete-repair' },
  { label: service.data.title }
];

// Build significantLink array (MA-only for concrete repair)
const significantLinks = [
  // Related concrete repair services
  ...relatedServices.map(s => `https://www.attackacrack.com/concrete-repair/${s.id.replace(/\.md$/, '')}`),
  // MA state hub and concrete repair hub
  "https://www.attackacrack.com/massachusetts",
  "https://www.attackacrack.com/concrete-repair",
  // Sample MA city pages
  ...maLocations.slice(0, 4).map(l => `https://www.attackacrack.com/massachusetts/${l.id.replace(/\.md$/, '').replace(/^massachusetts\//, '')}`)
];

// Build mentions array
const mentions = [
  // Service type
  { "@type": "Thing", "name": "Concrete Repair" },
  { "@type": "Thing", "name": service.data.title },
  // State served (MA only)
  { "@type": "Place", "name": "Massachusetts" }
];

// Build ImageObject for hero image
const heroImg = service.data.heroImage;
const serviceImageObject = heroImg ? {
  "@type": "ImageObject",
  "name": `${service.data.title} — concrete repair service`,
  "description": service.data.excerpt,
  "contentUrl": `https://www.attackacrack.com${heroImg}`,
  "url": `https://www.attackacrack.com/concrete-repair/${serviceSlug}`,
  "width": 800,
  "height": 600
} : null;

// Service schema with LLM-ready properties
const serviceSchema = {
  "@type": "Service",
  "name": service.data.title,
  "description": service.data.metaDescription,
  "url": `https://www.attackacrack.com/concrete-repair/${service.id.replace(/\.md$/, '')}`,
  ...(serviceImageObject && { "image": serviceImageObject }),
  "provider": {
    "@type": "HomeAndConstructionBusiness",
    "name": "Attack A Crack Foundation Repair",
    "telephone": phoneMA
  },
  "areaServed": {
    "@type": "State",
    "name": "Massachusetts"
  },
  "serviceType": "Concrete Repair",
  "aggregateRating": aggregateRatingSchema,
  // LLM-ready properties
  "significantLink": significantLinks,
  "mentions": mentions
};

// FAQ schema if FAQs exist
const faqSchema = service.data.faqs && service.data.faqs.length > 0 ? {
  "@type": "FAQPage",
  "mainEntity": service.data.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;

const schemas = faqSchema ? [serviceSchema, faqSchema] : [serviceSchema];
---

<Layout 
  title={service.data.metaTitle} 
  description={service.data.metaDescription}
  customSchema={schemas}
  breadcrumbItems={breadcrumbItems}
>
	<LocationModal />
	<Navbar />

	<main class="pt-20 lg:pt-24">
		<!-- Hero Section -->
		<section class="py-16 lg:py-24 bg-aac-blue text-white relative overflow-hidden">
			<div class="absolute top-0 right-0 w-1/2 h-full bg-white/5 skew-x-12 translate-x-1/2"></div>
			<div class="max-w-7xl mx-auto px-6 relative z-10">
				<Breadcrumbs items={breadcrumbItems} class="mb-8 [&_a]:text-white/80 [&_a:hover]:text-white [&_span]:text-white [&_svg]:text-white/60" />

				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<div>
						<div class="inline-flex items-center gap-2 px-4 py-2 bg-aac-yellow text-aac-dark rounded-full text-[10px] font-black uppercase tracking-widest mb-6">
							<Icon name="MapPin" size={14} /> Massachusetts Only
						</div>
						<h1 class="text-4xl lg:text-6xl font-black tracking-tighter mb-6 leading-none">
							{service.data.title}
						</h1>
						<p class="text-xl text-white mb-8">
							{service.data.excerpt}
						</p>
						<div class="flex flex-wrap gap-4">
							<a href={phoneMAHref} class="bg-aac-yellow text-aac-dark px-8 py-4 rounded-xl font-black uppercase tracking-widest text-[11px] shadow-[4px_4px_0px_0px_rgba(0,0,0,0.2)] hover:translate-y-[-2px] transition-all inline-flex items-center gap-2">
								<Icon name="Phone" size={16} />
								Call {phoneMA}
							</a>
							<button class="open-modal bg-white/10 backdrop-blur-sm text-white px-8 py-4 rounded-xl font-black uppercase tracking-widest text-[11px] border border-white/20 hover:bg-white/20 transition-all inline-flex items-center gap-2">
								<Icon name="MessageSquare" size={16} />
								Get Free Quote
							</button>
						</div>
					</div>

					<!-- Service Image -->
					{service.data.beforeImage && service.data.afterImage ? (
						<div class="relative hidden lg:block">
							<div class="aspect-[4/3] rounded-[32px] overflow-hidden border-4 border-white/20 shadow-2xl">
								<div class="resurfacing-image-container relative w-full h-full">
									<img
										src={webpSrc(service.data.beforeImage)}
										srcset={projectSrcset(service.data.beforeImage)}
										sizes="(max-width: 768px) 100vw, 50vw"
										data-before={webpSrc(service.data.beforeImage)}
										data-after={webpSrc(service.data.afterImage)}
										alt={`${service.data.title} - Before and After`}
										class="resurfacing-hero-image w-full h-full object-cover transition-opacity duration-500"
										width="800"
										height="600"
									/>
									<div class="status-badge absolute top-4 left-4 bg-aac-dark/80 backdrop-blur-md text-white text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-lg border border-white/20">
										Before
									</div>
								</div>
							</div>
							<button class="toggle-image absolute -bottom-4 left-1/2 -translate-x-1/2 bg-aac-dark text-white px-6 py-3 rounded-full font-black uppercase tracking-widest text-[10px] shadow-lg hover:bg-aac-dark/90 transition-all inline-flex items-center gap-2 border-4 border-white">
								<Icon name="ArrowRight" size={14} />
								See After
							</button>
						</div>
					) : (service.data.heroImage || service.data.afterImage) && (
						<div class="hidden lg:block aspect-[4/3] rounded-[32px] overflow-hidden border-4 border-white/20 shadow-2xl">
							<img
								src={webpSrc(service.data.heroImage || service.data.afterImage)}
								srcset={projectSrcset(service.data.heroImage || service.data.afterImage)}
								sizes="(max-width: 768px) 100vw, 50vw"
								alt={service.data.title}
								class="w-full h-full object-cover"
								width="800"
								height="600"
							/>
						</div>
					)}
				</div>
			</div>
		</section>

		<!-- Main Content -->
		<section class="py-16 lg:py-24 bg-white">
			<div class="max-w-4xl mx-auto px-6">
				<article class="prose prose-lg prose-zinc max-w-none prose-headings:font-black prose-headings:tracking-tight prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-4 prose-p:leading-relaxed prose-a:text-aac-blue prose-a:font-bold prose-a:no-underline hover:prose-a:underline prose-strong:text-aac-dark prose-ul:my-6 prose-li:my-2">
					<Content />
				</article>
			</div>
		</section>

		<!-- FAQs Section -->
		{service.data.faqs && service.data.faqs.length > 0 && (
			<section class="py-16 lg:py-24 bg-zinc-50">
				<div class="max-w-4xl mx-auto px-6">
					<div class="text-center mb-12">
						<h2 class="text-4xl font-black tracking-tighter text-aac-dark">
							Frequently Asked Questions
						</h2>
					</div>

					<div class="space-y-4">
						{service.data.faqs.map((faq) => (
							<details class="group bg-white rounded-2xl border-2 border-zinc-100 overflow-hidden">
								<summary class="flex justify-between items-center p-6 cursor-pointer font-black text-lg hover:text-aac-blue transition-colors list-none">
									{faq.question}
									<span class="text-aac-blue shrink-0 ml-4 group-open:rotate-180 transition-transform">
										<Icon name="ChevronRight" size={20} class="rotate-90" />
									</span>
								</summary>
								<div class="px-6 pb-6 text-zinc-600 leading-relaxed">
									{faq.answer}
								</div>
							</details>
						))}
					</div>
				</div>
			</section>
		)}

		<!-- Featured Projects -->
		<ProjectCards
			projects={concreteProjects}
			heading={`Featured ${service.data.title} Projects`}
		/>

		<!-- Helpful Guides -->
		{relatedBlogPosts.length > 0 && (
			<section class="py-16 lg:py-24 bg-white border-t border-zinc-100">
				<div class="max-w-7xl mx-auto px-6">
					<div class="text-center mb-12">
						<div class="inline-flex items-center gap-2 px-4 py-2 bg-aac-blue/10 text-aac-blue rounded-full text-[10px] font-black uppercase tracking-widest mb-6 border border-aac-blue/20">
							<Icon name="Info" size={14} /> Helpful Guides
						</div>
						<h2 class="text-3xl font-black tracking-tighter text-aac-dark">
							Learn More About {service.data.title}
						</h2>
					</div>
					<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
						{relatedBlogPosts.map((post) => (
							<a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="group bg-zinc-50 rounded-2xl overflow-hidden border-2 border-zinc-100 hover:border-aac-blue transition-all">
								{post.data.heroImage && (
									<div class="aspect-video overflow-hidden">
										<img
											src={webpSrc(post.data.heroImage)}
											srcset={projectSrcset(post.data.heroImage)}
											sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw"
											alt={post.data.heroImageAlt || post.data.title}
											class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
											width="640"
											height="360"
											loading="lazy"
										/>
									</div>
								)}
								<div class="p-5">
									<h3 class="font-black text-sm group-hover:text-aac-blue transition-colors line-clamp-2">
										{post.data.title}
									</h3>
									<p class="text-zinc-500 text-xs mt-2 line-clamp-2">{post.data.excerpt}</p>
								</div>
							</a>
						))}
					</div>
					<div class="text-center mt-8">
						<a href="/blog" class="inline-flex items-center gap-2 text-aac-dark font-black uppercase tracking-widest text-sm hover:text-aac-blue transition-colors">
							View All Articles <Icon name="ArrowRight" size={16} />
						</a>
					</div>
				</div>
			</section>
		)}

		<!-- Related Services -->
		{relatedServices.length > 0 && (
			<section class="py-16 lg:py-24 bg-white border-t border-zinc-100">
				<div class="max-w-7xl mx-auto px-6">
					<div class="text-center mb-12">
						<h2 class="text-3xl font-black tracking-tighter text-aac-dark">
							Other Repair Services
						</h2>
					</div>

					<div class="grid md:grid-cols-3 gap-8">
						{relatedServices.map((related) => (
							<a href={`/concrete-repair/${related.id.replace(/\.md$/, '')}`} class="group bg-zinc-50 p-6 rounded-2xl border-2 border-zinc-100 hover:border-aac-blue transition-all">
								<div class="w-12 h-12 bg-aac-blue/10 text-aac-blue rounded-xl flex items-center justify-center mb-4 group-hover:bg-aac-blue group-hover:text-white transition-colors">
									<Icon name={related.data.icon} size={24} />
								</div>
								<h3 class="text-xl font-black mb-2 group-hover:text-aac-blue transition-colors">
									{related.data.title}
								</h3>
								<p class="text-zinc-600 text-sm line-clamp-2">
									{related.data.excerpt}
								</p>
							</a>
						))}
					</div>
				</div>
			</section>
		)}

		<!-- Service Areas Section (MA Only) -->
		<section class="py-12 bg-zinc-50 border-t border-zinc-100">
			<div class="max-w-7xl mx-auto px-6">
				<h2 class="text-2xl font-black tracking-tighter text-aac-dark mb-6 text-center">
					{service.data.title} Available In Massachusetts
				</h2>
				<div class="flex flex-wrap justify-center gap-2">
					{maLocations.map(loc => (
						<a
							href={`/massachusetts/${loc.id.replace(/\.md$/, '').replace(/^massachusetts\//, '')}`}
							class="px-3 py-1 bg-white border border-zinc-200 rounded-full text-sm hover:border-aac-blue hover:text-aac-blue transition-colors"
						>
							{loc.data.city}
						</a>
					))}
					{allLocations.filter(l => l.data.stateAbbr === 'MA').length > 8 && (
						<a href="/massachusetts" class="px-3 py-1 bg-aac-blue/10 text-aac-blue rounded-full text-sm font-bold hover:bg-aac-blue hover:text-white transition-colors">
							+{allLocations.filter(l => l.data.stateAbbr === 'MA').length - 8} more cities
						</a>
					)}
				</div>
				<p class="text-center text-sm text-zinc-500 mt-4">
					<Icon name="MapPin" size={14} class="inline mr-1" />
					Concrete repair services available in Massachusetts only
				</p>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-16 lg:py-24 bg-aac-dark text-white">
			<div class="max-w-4xl mx-auto px-6 text-center">
				<h2 class="text-4xl lg:text-5xl font-black tracking-tighter mb-6">
					Ready for Your <span class="text-aac-yellow">Free Quote?</span>
				</h2>
				<p class="text-xl text-zinc-400 mb-10">
					Contact us for a free assessment. We'll evaluate your concrete and provide an honest quote.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href={phoneMAHref} class="bg-aac-yellow text-aac-dark px-10 py-5 rounded-xl font-black uppercase tracking-widest text-sm hover:translate-y-[-2px] transition-all inline-flex items-center justify-center gap-2 border-2 border-aac-dark">
						<Icon name="Phone" size={20} />
						{phoneMA}
					</a>
					<button class="open-modal bg-white/10 text-white px-10 py-5 rounded-xl font-black uppercase tracking-widest text-sm hover:bg-white/20 transition-all border border-white/20 inline-flex items-center justify-center gap-2">
						<Icon name="MessageSquare" size={20} />
						Text Photos
					</button>
				</div>
				<p class="text-zinc-400 mt-8 text-sm">
					<Icon name="MapPin" size={14} class="inline mr-1" />
					Concrete repair available in Massachusetts only
				</p>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<script>
	// Before/After image toggle
	document.querySelectorAll('.toggle-image').forEach(button => {
		const container = button.closest('section')?.querySelector('.resurfacing-image-container');
		if (!container) return;

		const img = container.querySelector('.resurfacing-hero-image') as HTMLImageElement;
		const badge = container.querySelector('.status-badge') as HTMLElement;
		const beforeUrl = img.dataset.before;
		const afterUrl = img.dataset.after;
		let isAfter = false;

		button.addEventListener('click', () => {
			img.style.opacity = '0';
			setTimeout(() => {
				if (isAfter) {
					if (beforeUrl) img.src = beforeUrl;
					badge.textContent = 'Before';
					button.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg> See After';
				} else {
					if (afterUrl) img.src = afterUrl;
					badge.textContent = 'After';
					button.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg> See Before';
				}
				isAfter = !isAfter;
				img.style.opacity = '1';
			}, 300);
		});
	});
</script>
