---
import '../styles/global.css';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
}

const { 
	title, 
	description = "Attack A Crack foundation repair, a trusted family-owned concrete foundation repair contractor, has served New England for 20+ years.",
	image = "https://www.attackacrack.com/images/logo.jpg",
	canonicalURL = Astro.url.href
} = Astro.props;

const CT_NUMBER = "860-573-8760";
const MA_NUMBER = "617-668-1677";

// Build page title - don't append brand if already included
const pageTitle = title.includes('Attack A Crack') ? title : `${title} | Attack A Crack`;

// JSON-LD Schema for Local Business
const schema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Attack A Crack Foundation Repair",
  "alternateName": "Attack A Crack",
  "image": "https://www.attackacrack.com/images/logo.jpg",
  "@id": "https://attackacrack.com/#organization",
  "url": "https://attackacrack.com",
  "telephone": CT_NUMBER,
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Amston",
    "addressLocality": "Amston",
    "addressRegion": "CT",
    "postalCode": "06231",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 41.6151,
    "longitude": -72.3484
  },
  "areaServed": [
    {
      "@type": "State",
      "name": "Connecticut"
    },
    {
      "@type": "State",
      "name": "Massachusetts"
    }
  ],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
      "Sunday"
    ],
    "opens": "00:00",
    "closes": "23:59"
  },
  "sameAs": [
    "https://www.facebook.com/attackacrack"
  ]
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalURL} />
		<meta name="geo.region" content="US-CT" />
		<meta name="geo.placename" content="Amston" />
		<meta name="geo.position" content="41.6151;-72.3484" />
		<meta name="ICBM" content="41.6151, -72.3484" />
		<title>{pageTitle}</title>

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />

		<!-- Schema.org -->
		<script type="application/ld+json" set:html={JSON.stringify(schema)} />

		<!-- Preload critical fonts -->
		<link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/space-grotesk-latin.woff2" as="font" type="font/woff2" crossorigin />
	</head>
	<body class="bg-white text-aac-dark font-sans selection:bg-aac-yellow selection:text-aac-dark antialiased">
		<slot />
		<SpeedInsights />

	</body>
</html>
