---
import '../styles/global.css';
import SpeedInsights from '@vercel/speed-insights/astro';
import SEOHead from '../components/SEOHead.astro';
import { phoneCT, phoneMA, addressCT } from '../utils/contact';

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
	preloadHeroImage?: boolean;
	// Location-specific overrides for Schema/SEO
	city?: string;
	state?: string;
	zip?: string;
	coordinates?: { lat: number; lng: number };
	customSchema?: Record<string, unknown> | Record<string, unknown>[];
	breadcrumbItems?: { label: string; href?: string }[];
}

const GA4_ID = import.meta.env.PUBLIC_GA4_ID;

const {
	title,
	description = "Attack A Crack foundation repair, a trusted family-owned concrete foundation repair contractor, has served New England for 20+ years.",
	image = "/images/logo.jpg",
	canonicalURL = Astro.url.href,
	preloadHeroImage = false,
	city = "Amston",
	state = "CT",
	zip = "06231",
	coordinates,
	customSchema,
	breadcrumbItems
} = Astro.props;

// Format coordinates for meta tags if present
const geoPosition = coordinates ? `${coordinates.lat};${coordinates.lng}` : undefined;

const CT_NUMBER = phoneCT;
const MA_NUMBER = phoneMA;

// JSON-LD Schema for Local Business - Default if no customSchema provided
const defaultSchema = {
  "@type": "HomeAndConstructionBusiness",
  "name": "Attack A Crack Foundation Repair",
  "alternateName": "Attack A Crack",
  "image": "https://www.attackacrack.com/images/logo.jpg",
  "@id": "https://attackacrack.com/#organization",
  "url": "https://attackacrack.com",
  "telephone": state === 'MA' ? MA_NUMBER : CT_NUMBER,
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": city === 'Amston' ? addressCT.split(',')[0] : city,
    "addressLocality": city,
    "addressRegion": state,
    "postalCode": zip,
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "State", "name": "Connecticut" },
    { "@type": "State", "name": "Massachusetts" },
    { "@type": "State", "name": "Rhode Island" },
    { "@type": "State", "name": "New Hampshire" },
    { "@type": "State", "name": "Maine" }
  ],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
    "opens": "00:00",
    "closes": "23:59"
  },
  "sameAs": ["https://www.facebook.com/attackacrack"],
  "founder": {
    "@type": "Person",
    "name": "Luc Richard",
    "jobTitle": "Founder & Lead Foundation Expert"
  },
  "foundingDate": "2002",
  "knowsAbout": [
    "Foundation Repair",
    "Concrete Crack Injection",
    "Epoxy & Polyurethane Resin",
    "Carbon Fiber Structural Reinforcement",
    "New England Soil Conditions"
  ]
};

// Breadcrumb Schema
const breadcrumbSchema = breadcrumbItems ? {
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    "item": item.href ? new URL(item.href, Astro.site).href : undefined
  }))
} : null;

// Use customSchema if provided, otherwise defaultSchema
const finalSchema = customSchema 
  ? (Array.isArray(customSchema) ? customSchema : [customSchema])
  : [defaultSchema];

if (breadcrumbSchema) {
  finalSchema.push(breadcrumbSchema);
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<SEOHead 
			title={title}
			description={description}
			image={image}
			canonical={canonicalURL}
			geoPlacename={city}
			geoRegion={`US-${state}`}
			geoPosition={geoPosition}
		/>

		<!-- Schema.org -->
		{finalSchema.map(s => (
			<script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", ...s })} />
		))}

		<!-- Preload critical fonts -->
		<link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/space-grotesk-latin.woff2" as="font" type="font/woff2" crossorigin />

		{GA4_ID && (
			<>
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
				<script is:inline define:vars={{ GA4_ID }}>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', GA4_ID);
				</script>
			</>
		)}

		{preloadHeroImage && (
			<link rel="preload" href="/images/hero-slide-1.webp" as="image" type="image/webp"
				fetchpriority="high"
				imagesrcset="/images/hero-slide-1-sm.webp 600w, /images/hero-slide-1.webp 1200w"
				imagesizes="(max-width: 1024px) calc(100vw - 48px), 640px" />
		)}
	</head>
	<body class="bg-white text-aac-dark font-sans selection:bg-aac-yellow selection:text-aac-dark antialiased">
		<slot />
		<SpeedInsights />
		<script>
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.1 }
			);
			document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));
		</script>
	</body>
</html>
