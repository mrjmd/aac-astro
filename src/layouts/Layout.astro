---
import '../styles/global.css';
import SpeedInsights from '@vercel/speed-insights/astro';
import Analytics from '@vercel/analytics/astro';
import SEOHead from '../components/SEOHead.astro';
import StickyCTA from '../components/StickyCTA.astro';
import { phoneCT, phoneMA, addressCT } from '../utils/contact';
import { reviewCountDisplay } from '../utils/reviews';

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
	preloadHeroImage?: boolean;
	pageType?: 'home' | 'city' | 'service' | 'blog' | 'about' | 'hub' | 'partner' | 'project' | 'legal' | 'other';
	// Location-specific overrides for Schema/SEO
	city?: string;
	state?: string;
	zip?: string;
	coordinates?: { lat: number; lng: number };
	customSchema?: Record<string, unknown> | Record<string, unknown>[];
	breadcrumbItems?: { label: string; href?: string }[];
}

const GA4_ID = import.meta.env.PUBLIC_GA4_ID;
const GOOGLE_ADS_MA_ID = import.meta.env.PUBLIC_GOOGLE_ADS_MA_ID;
// TODO: Add PUBLIC_GOOGLE_ADS_CT_ID once CT Google Ads account is linked to MCC
// const GOOGLE_ADS_CT_ID = import.meta.env.PUBLIC_GOOGLE_ADS_CT_ID;

const {
	title,
	description = "Attack A Crack foundation repair, a trusted family-owned concrete foundation repair contractor, has served New England for 20+ years.",
	image = "/images/logo.jpg",
	canonicalURL = Astro.url.href,
	preloadHeroImage = false,
	city = "Amston",
	state = "CT",
	zip = "06231",
	coordinates,
	customSchema,
	breadcrumbItems,
	pageType
} = Astro.props;

// Format coordinates for meta tags if present
const geoPosition = coordinates ? `${coordinates.lat};${coordinates.lng}` : undefined;

const CT_NUMBER = phoneCT;
const MA_NUMBER = phoneMA;

// Determine sticky CTA behavior based on page context
// State pages: direct call + direct SMS to that state's number
// Generic pages: both buttons open modals (visitor picks their state)
const path = Astro.url.pathname;
const isCTPage = path.startsWith('/connecticut');
const isMAPage = path.startsWith('/massachusetts');
const isRIPage = path.startsWith('/rhode-island');
const isNHPage = path.startsWith('/new-hampshire');
const isMEPage = path.startsWith('/maine');
const isStatePage = isCTPage || isMAPage || isRIPage || isNHPage || isMEPage;
const stickyPhone = isCTPage ? CT_NUMBER : (isMAPage || isRIPage || isNHPage || isMEPage) ? MA_NUMBER : undefined;
const stickyPhoneHref = stickyPhone ? `tel:${stickyPhone}` : undefined;
const stickySmsHref = isStatePage ? `sms:${stickyPhone}` : undefined;

// JSON-LD Schema for Local Business - Default if no customSchema provided
const defaultSchema = {
  "@type": "HomeAndConstructionBusiness",
  "name": "Attack A Crack Foundation Repair",
  "alternateName": "Attack A Crack",
  "image": "https://www.attackacrack.com/images/logo.jpg",
  "@id": "https://attackacrack.com/#organization",
  "url": "https://attackacrack.com",
  "telephone": state === 'MA' ? MA_NUMBER : CT_NUMBER,
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": city === 'Amston' ? addressCT.split(',')[0] : city,
    "addressLocality": city,
    "addressRegion": state,
    "postalCode": zip,
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "State", "name": "Connecticut" },
    { "@type": "State", "name": "Massachusetts" },
    { "@type": "State", "name": "Rhode Island" },
    { "@type": "State", "name": "New Hampshire" },
    { "@type": "State", "name": "Maine" }
  ],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
    "opens": "00:00",
    "closes": "23:59"
  },
  "sameAs": [
    "https://www.facebook.com/attackacrack",
    "https://www.instagram.com/attackacrack/",
    "https://www.linkedin.com/company/attack-a-crack",
    "https://www.bbb.org/us/ct/north-windham/profile/concrete-repair/attack-a-crack-0111-74000203",
    "https://www.yelp.com/biz/attack-a-crack-amston-2",
    "https://www.yelp.com/biz/attack-a-crack-quincy",
    "https://maps.app.goo.gl/9sVxWhFWN68Q2Gq57",
    "https://maps.app.goo.gl/FWp1dsxHvVyfHFRJ9"
  ],
  "hasCredential": [
    {
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": "Home Improvement Contractor License",
      "recognizedBy": { "@type": "Organization", "name": "State of Connecticut" },
      "identifier": "HIC.0629164"
    },
    {
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": "Home Improvement Contractor License",
      "recognizedBy": { "@type": "Organization", "name": "Commonwealth of Massachusetts" },
      "identifier": "214356"
    }
  ],
  "memberOf": [
    { "@type": "Organization", "name": "American Society of Home Inspectors - New England Chapter" },
    { "@type": "Organization", "name": "Greater Boston Association of Realtors" },
    { "@type": "Organization", "name": "Quincy Chamber of Commerce" }
  ],
  "founder": {
    "@type": "Person",
    "name": "Luc Richard",
    "jobTitle": "Founder & Lead Foundation Expert"
  },
  "foundingDate": "2002",
  "knowsAbout": [
    "Foundation Repair",
    "Concrete Crack Injection",
    "Epoxy & Polyurethane Resin",
    "Carbon Fiber Structural Reinforcement",
    "New England Soil Conditions"
  ]
};

// Breadcrumb Schema
const breadcrumbSchema = breadcrumbItems ? {
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    "item": item.href ? new URL(item.href, Astro.site).href : undefined
  }))
} : null;

// Use customSchema if provided, otherwise defaultSchema
const finalSchema = customSchema 
  ? (Array.isArray(customSchema) ? customSchema : [customSchema])
  : [defaultSchema];

if (breadcrumbSchema) {
  finalSchema.push(breadcrumbSchema);
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<script is:inline>(function(){var m=document.cookie.match(/(?:^|; )geo_region=(\w+)/);if(m)document.documentElement.classList.add('geo-'+m[1])})()</script>
		<meta name="theme-color" content="#1a1a1a" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<SEOHead 
			title={title}
			description={description}
			image={image}
			canonical={canonicalURL}
			geoPlacename={city}
			geoRegion={`US-${state}`}
			geoPosition={geoPosition}
		/>

		<!-- Schema.org -->
		{finalSchema.map(s => (
			<script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", ...s })} />
		))}

		<!-- Preload critical fonts -->
		<link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/space-grotesk-latin.woff2" as="font" type="font/woff2" crossorigin />

		{GA4_ID && (
			<>
				<link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
				<link rel="preconnect" href="https://www.google-analytics.com" crossorigin />
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
				<script is:inline define:vars={{ GA4_ID, GOOGLE_ADS_MA_ID, pageType }}>
					window.dataLayer = window.dataLayer || [];
					window.gtag = function(){dataLayer.push(arguments);};
					gtag('js', new Date());
					gtag('set', { page_type: pageType || 'unknown' });
					gtag('config', GA4_ID);
					if (GOOGLE_ADS_MA_ID) gtag('config', GOOGLE_ADS_MA_ID);
					// TODO: Uncomment when CT Google Ads account is linked to MCC
					// if (GOOGLE_ADS_CT_ID) gtag('config', GOOGLE_ADS_CT_ID);

					// GCLID capture — store Google Ads click ID for offline conversion imports
					var gclidParam = new URLSearchParams(window.location.search).get('gclid');
					if (gclidParam) {
						localStorage.setItem('gclid', gclidParam);
						localStorage.setItem('gclid_at', new Date().toISOString());
						localStorage.setItem('gclid_landing', window.location.pathname);
					}
					var storedGclid = localStorage.getItem('gclid') || '';

					// Geo-personalization tracking
					var geoRegion = (document.cookie.match(/(?:^|; )geo_region=(\w+)/) || [])[1] || 'none';
					if (geoRegion !== 'none') {
						gtag('event', 'geo_personalized', {
							geo_region: geoRegion,
							page_path: window.location.pathname,
							page_type: pageType || 'unknown',
						});
					}

					// GA4 ready gate — wait for gtag.js to fully initialize before
					// registering click handlers. Without this, clicks that fire before
					// gtag processes the config produce sessions with (not set) source/medium
					// because the page_view hasn't established session context yet.
					var ga4Ready = false;
					gtag('get', GA4_ID, 'client_id', function(cid) {
						ga4Ready = true;
						if (cid) gtag('set', { client_id: cid });
					});

					// Phone/text click tracking — fires GA4 events (conversions imported into Google Ads via GA4 link)
					var CT_NUMBER = '8605738760';
					var MA_NUMBER = '6176681677';

					function inferClickLocation(el) {
						if (el.closest('[data-sticky-cta]')) return 'sticky_cta';
						if (el.closest('[data-modal]')) return 'modal';
						if (el.closest('[data-hero]')) return 'hero';
						if (el.closest('nav')) return 'navbar';
						if (el.closest('footer')) return 'footer';
						return 'inline';
					}

					function fireClickEvent(eventName, params) {
						if (storedGclid) params.ad_click_id = storedGclid;

						if (ga4Ready) {
							gtag('event', eventName, params);
						} else {
							// GA4 not ready yet — wait up to 3s, then fire anyway
							// (better to log with partial data than lose the conversion)
							var attempts = 0;
							var poll = setInterval(function() {
								attempts++;
								if (ga4Ready || attempts >= 30) {
									clearInterval(poll);
									gtag('event', eventName, params);
								}
							}, 100);
						}
					}

					document.addEventListener('click', function(e) {
						var link = e.target.closest('a');
						if (!link) return;
						var href = link.getAttribute('href');
						if (!href) return;

						if (href.indexOf('tel:') === 0) {
							var number = href.replace('tel:', '').replace(/\D/g, '');
							var region = number.indexOf(CT_NUMBER) !== -1 ? 'CT' : 'MA';

							fireClickEvent('phone_call_click', {
								phone_region: region,
								phone_number: number,
								click_location: inferClickLocation(link),
								page_path: window.location.pathname,
								page_type: document.body.dataset.pageType || 'unknown',
								geo_detected: geoRegion,
							});

						} else if (href.indexOf('sms:') === 0) {
							var smsNumber = href.replace(/sms:[+]?/, '').replace(/\D/g, '');
							var smsRegion = smsNumber.indexOf(CT_NUMBER) !== -1 ? 'CT' : 'MA';

							fireClickEvent('text_message_click', {
								phone_region: smsRegion,
								phone_number: smsNumber,
								click_location: inferClickLocation(link),
								page_path: window.location.pathname,
								page_type: document.body.dataset.pageType || 'unknown',
								geo_detected: geoRegion,
							});
						}
					});
				</script>
			</>
		)}

		<!-- Microsoft Clarity -->
		<script is:inline>
			(function(c,l,a,r,i,t,y){
				c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
				t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
				y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
			})(window, document, "clarity", "script", "w2bnacndl9");
		</script>

		{preloadHeroImage && (
			<link rel="preload" href="/images/hero-slide-1.webp" as="image" type="image/webp"
				fetchpriority="high"
				imagesrcset="/images/hero-slide-1-sm.webp 600w, /images/hero-slide-1-800w.webp 800w, /images/hero-slide-1.webp 1200w"
				imagesizes="(max-width: 1024px) calc(100vw - 48px), 640px" />
		)}
	</head>
	<body class="bg-white text-aac-dark font-sans selection:bg-aac-yellow selection:text-aac-dark antialiased" data-page-type={pageType}>
		<slot />
		<SpeedInsights />
		<Analytics />
		<StickyCTA
			phoneHref={stickyPhoneHref}
			smsHref={stickySmsHref}
		/>
		<script>
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.1 }
			);
			document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));

		// --- YouTube facade: load real player on click ---
		const trackYTIframe = (iframe: HTMLIFrameElement, videoId: string, videoTitle: string) => {
			if (typeof window.gtag !== 'function' || !(window as any).YT) return;
			new (window as any).YT.Player(iframe, {
				events: {
					onStateChange: (event: any) => {
						const pp = window.location.pathname;
						const pt = document.body.dataset.pageType || 'unknown';
						if (event.data === (window as any).YT.PlayerState.PLAYING) {
							if (!(iframe as any)._aacPlayed) {
								(iframe as any)._aacPlayed = true;
								window.gtag('event', 'video_play', { video_id: videoId, video_title: videoTitle, page_path: pp, page_type: pt });
							}
						} else if (event.data === (window as any).YT.PlayerState.ENDED) {
							window.gtag('event', 'video_complete', { video_id: videoId, video_title: videoTitle, page_path: pp, page_type: pt });
						}
					}
				}
			});
		};

		document.querySelectorAll<HTMLElement>('.yt-facade').forEach((el) => {
			const activate = () => {
				const id = el.dataset.videoId!;
				const title = el.dataset.videoTitle || '';
				const iframeStyle = el.dataset.iframeStyle || '';
				const iframeClass = el.dataset.iframeClass || '';
				const iframe = document.createElement('iframe');
				iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&enablejsapi=1&origin=${window.location.origin}`;
				iframe.title = title;
				iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
				iframe.allowFullscreen = true;
				iframe.style.cssText = `width:100%;height:100%;border:0;${iframeStyle}`;
				if (iframeClass) iframe.className = iframeClass;
				el.innerHTML = '';
				el.appendChild(iframe);
				el.classList.remove('cursor-pointer');
				el.removeAttribute('role');
				el.removeAttribute('tabindex');

				// Set up tracking — load YT API if needed
				if (typeof window.gtag === 'function') {
					if ((window as any).YT) {
						trackYTIframe(iframe, id, title);
					} else {
						if (!document.querySelector('script[src*="youtube.com/iframe_api"]')) {
							const s = document.createElement('script');
							s.src = 'https://www.youtube.com/iframe_api';
							document.head.appendChild(s);
						}
						const prev = (window as any).onYouTubeIframeAPIReady;
						(window as any).onYouTubeIframeAPIReady = () => {
							if (prev) prev();
							trackYTIframe(iframe, id, title);
						};
					}
				}
			};
			el.addEventListener('click', activate, { once: true });
			el.addEventListener('keydown', (e) => {
				if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); }
			}, { once: true });
		});

		// --- Engagement tracking (scroll depth, blog read-complete, video play/complete) ---
		if (typeof window.gtag === 'function') {
			const pt = document.body.dataset.pageType || 'unknown';
			const pp = window.location.pathname;

			// 1. Scroll depth on all pages (25/50/75/100%)
			{
				const scrollMarkers = [25, 50, 75, 100];
				const scrollFired: Record<number, boolean> = {};
				window.addEventListener('scroll', () => {
					const scrollPct = Math.round((window.scrollY + window.innerHeight) / document.documentElement.scrollHeight * 100);
					for (const mark of scrollMarkers) {
						if (scrollPct >= mark && !scrollFired[mark]) {
							scrollFired[mark] = true;
							window.gtag('event', 'scroll_depth', {
								depth: mark + '%',
								page_type: pt,
								page_path: pp,
							});
						}
					}
				}, { passive: true });
			}

			// 2. Blog read-complete (fires when reader reaches end of article)
			if (pt === 'blog') {
				const article = document.querySelector('article.prose');
				if (article) {
					const readObserver = new IntersectionObserver((entries) => {
						if (entries[0].isIntersecting) {
							const slug = pp.replace(/^\/blog\//, '').replace(/\/$/, '');
							window.gtag('event', 'blog_read_complete', {
								post_slug: slug,
								page_path: pp,
							});
							readObserver.disconnect();
						}
					}, { threshold: 0.1 });
					const lastChild = article.lastElementChild;
					if (lastChild) readObserver.observe(lastChild);
				}
			}

			// 3. Video play/complete tracking — handled by facade click handler above
			const ytIframes = document.querySelectorAll<HTMLIFrameElement>('iframe[src*="youtube.com/embed"]');
			if (ytIframes.length > 0) {
				ytIframes.forEach((iframe) => {
					const src = iframe.getAttribute('src');
					if (src && !src.includes('enablejsapi')) {
						iframe.setAttribute('src', src + (src.includes('?') ? '&' : '?') + 'enablejsapi=1&origin=' + window.location.origin);
					}
				});

				const ytScript = document.createElement('script');
				ytScript.src = 'https://www.youtube.com/iframe_api';
				document.head.appendChild(ytScript);

				(window as any).onYouTubeIframeAPIReady = () => {
					ytIframes.forEach((iframe) => {
						const videoSrc = iframe.getAttribute('src') || '';
						const videoIdMatch = videoSrc.match(/embed\/([^?&]+)/);
						const videoId = videoIdMatch ? videoIdMatch[1] : 'unknown';
						const videoTitle = iframe.getAttribute('title') || 'unknown';

						new (window as any).YT.Player(iframe, {
							events: {
								onStateChange: (event: any) => {
									if (event.data === (window as any).YT.PlayerState.PLAYING) {
										if (!(iframe as any)._aacPlayed) {
											(iframe as any)._aacPlayed = true;
											window.gtag('event', 'video_play', {
												video_id: videoId,
												video_title: videoTitle,
												page_path: pp,
												page_type: pt,
											});
										}
									} else if (event.data === (window as any).YT.PlayerState.ENDED) {
										window.gtag('event', 'video_complete', {
											video_id: videoId,
											video_title: videoTitle,
											page_path: pp,
											page_type: pt,
										});
									}
								}
							}
						});
					});
				};
			}
		}
		</script>
	</body>
</html>
