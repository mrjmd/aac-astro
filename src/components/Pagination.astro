---
import Icon from './Icon.astro';

interface Props {
  currentPage: number;
  lastPage: number;
  prevUrl: string | undefined;
  nextUrl: string | undefined;
  baseUrl: string;
}

const { currentPage, lastPage, prevUrl, nextUrl, baseUrl } = Astro.props;

// Don't render if only one page
if (lastPage <= 1) return;

// Generate page numbers to display
function getPageNumbers(current: number, last: number): (number | '...')[] {
  if (last <= 5) return Array.from({ length: last }, (_, i) => i + 1);

  const pages: (number | '...')[] = [1];
  if (current > 3) pages.push('...');
  for (let i = Math.max(2, current - 1); i <= Math.min(last - 1, current + 1); i++) {
    pages.push(i);
  }
  if (current < last - 2) pages.push('...');
  pages.push(last);
  return pages;
}

const pages = getPageNumbers(currentPage, lastPage);

function pageUrl(page: number): string {
  return page === 1 ? baseUrl : `${baseUrl}/${page}`;
}
---

<nav aria-label="Blog pagination" class="flex items-center justify-center gap-2 mt-16">
  {prevUrl ? (
    <a href={prevUrl} class="flex items-center gap-2 px-4 py-2 bg-white border-2 border-zinc-200 rounded-xl font-bold text-sm hover:border-aac-blue hover:text-aac-blue transition-colors">
      <Icon name="ArrowRight" size={14} class="rotate-180" />
      Previous
    </a>
  ) : (
    <span class="flex items-center gap-2 px-4 py-2 bg-zinc-100 border-2 border-zinc-100 rounded-xl font-bold text-sm text-zinc-600 cursor-not-allowed">
      <Icon name="ArrowRight" size={14} class="rotate-180" />
      Previous
    </span>
  )}

  <div class="flex items-center gap-1">
    {pages.map(page => (
      page === '...' ? (
        <span class="px-3 py-2 text-zinc-400">...</span>
      ) : page === currentPage ? (
        <span class="w-10 h-10 flex items-center justify-center bg-aac-dark text-white rounded-xl font-black text-sm">
          {page}
        </span>
      ) : (
        <a href={pageUrl(page)} class="w-10 h-10 flex items-center justify-center bg-white border-2 border-zinc-200 rounded-xl font-bold text-sm hover:border-aac-blue hover:text-aac-blue transition-colors">
          {page}
        </a>
      )
    ))}
  </div>

  {nextUrl ? (
    <a href={nextUrl} class="flex items-center gap-2 px-4 py-2 bg-white border-2 border-zinc-200 rounded-xl font-bold text-sm hover:border-aac-blue hover:text-aac-blue transition-colors">
      Next
      <Icon name="ArrowRight" size={14} />
    </a>
  ) : (
    <span class="flex items-center gap-2 px-4 py-2 bg-zinc-100 border-2 border-zinc-100 rounded-xl font-bold text-sm text-zinc-600 cursor-not-allowed">
      Next
      <Icon name="ArrowRight" size={14} />
    </span>
  )}
</nav>
