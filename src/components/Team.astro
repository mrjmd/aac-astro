---
import Icon from './Icon.astro';

const team = [
  { name: "Luc Richard", role: "Founder & Managing Partner", loc: "Connecticut", img: "/images/team/luc.webp" },
  { name: "Matt Davis", role: "Managing Partner", loc: "Massachusetts", img: "/images/team/matt.webp" },
  { name: "Edward Crowell", role: "Partnership Lead", loc: "Business Development", img: "/images/team/placeholder.svg" },
  { name: "Justin La Fontaine", role: "Lead Technician", loc: "Field Expert", img: "/images/team/justin.webp" },
  { name: "Mike Harrington", role: "Technician", loc: "Field Expert", img: "/images/team/mike.webp" }
];
---

<section id="about" data-animate class="py-16 md:py-24 bg-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-8 md:gap-16 items-center">
    <div>
      <p class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-zinc-400 mb-6">
        <Icon name="Users" size={14} /> OUR FAMILY OF FIXERS
      </p>
      <h2 class="text-4xl lg:text-7xl font-display font-black text-aac-dark tracking-tighter leading-none mb-8">
        Talk Directly to <br />
        <span class="text-aac-blue">The Experts.</span>
      </h2>
      <a href="/about" class="bg-aac-yellow text-aac-dark px-8 py-4 rounded-xl font-black uppercase tracking-widest text-[11px] border-2 border-aac-dark shadow-[4px_4px_0px_0px_rgba(26,26,26,0.05)] hover:translate-y-[-2px] transition-all inline-block mb-8">
        MEET THE TEAM
      </a>
      <p class="text-lg font-bold text-zinc-500 mb-12 leading-relaxed max-w-lg">
        When you call Attack A Crack, you're speaking directly with the people who understand foundation science. We focus on rapid response and honest diagnosis.
      </p>
      
      <div class="bg-aac-yellow/10 border-l-4 border-aac-yellow p-8 rounded-r-3xl flex gap-4 items-start max-w-lg">
        <div class="w-10 h-10 bg-aac-yellow rounded-xl flex items-center justify-center shrink-0">
          <Icon name="Info" size={20} class="text-aac-dark" />
        </div>
        <p class="text-sm font-bold text-aac-dark italic leading-relaxed">
          "We will talk you through your options including DIY repair if it's something you can handle yourself."
        </p>
      </div>
    </div>
    
    <div class="relative flex flex-col items-center gap-4">
      <!-- Top 2 (centered pyramid) -->
      <div class="grid grid-cols-6 gap-4 w-full md:grid-cols-2 md:max-w-sm">
        {team.slice(0, 2).map((member, i) => (
          <div class={`col-span-2 md:col-span-1 ${i === 0 ? 'col-start-2 md:col-start-auto' : ''} group bg-white p-4 rounded-3xl border-4 border-aac-dark shadow-[8px_8px_0px_0px_rgba(26,26,26,0.05)]`}>
            <div class="aspect-square rounded-2xl overflow-hidden mb-4">
              <img src={member.img} alt={member.name} class="w-full h-full object-cover object-top md:grayscale md:group-hover:grayscale-0 transition-all duration-500" referrerpolicy="no-referrer" />
            </div>
            <a href="/about" class="hover:text-aac-blue transition-colors">
              <h3 class="font-bold text-aac-dark text-sm">{member.name}</h3>
            </a>
            <p class="text-aac-blue text-[10px] font-bold uppercase tracking-widest mt-1">{member.role}</p>
            <p class="text-zinc-500 text-[9px] font-bold uppercase tracking-widest mt-1">{member.loc}</p>
          </div>
        ))}
      </div>
      <!-- Bottom 3 -->
      <div class="grid grid-cols-6 gap-4 w-full md:grid-cols-3">
        {team.slice(2).map((member) => (
          <div class="col-span-2 md:col-span-1 group bg-white p-4 rounded-3xl border-4 border-aac-dark shadow-[8px_8px_0px_0px_rgba(26,26,26,0.05)]">
            <div class="aspect-square rounded-2xl overflow-hidden mb-4">
              <img src={member.img} alt={member.name} class="w-full h-full object-cover object-top md:grayscale md:group-hover:grayscale-0 transition-all duration-500" referrerpolicy="no-referrer" />
            </div>
            <a href="/about" class="hover:text-aac-blue transition-colors">
              <h3 class="font-bold text-aac-dark text-sm">{member.name}</h3>
            </a>
            <p class="text-aac-blue text-[10px] font-bold uppercase tracking-widest mt-1">{member.role}</p>
            <p class="text-zinc-500 text-[9px] font-bold uppercase tracking-widest mt-1">{member.loc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
