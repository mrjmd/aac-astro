---
import Icon from './Icon.astro';
import { googleReviewsUrlCT, googleReviewsUrlMA } from '../utils/reviews';
import { phoneCT, phoneMA } from '../utils/contact';

const CT_NUMBER = phoneCT;
const MA_NUMBER = phoneMA;
---

<footer class="bg-white pt-16 md:pt-24 pb-20 lg:pb-12 border-t border-zinc-100">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 mb-10 md:mb-20">
      <div class="lg:col-span-5">
        <a href="/" class="flex items-center gap-3 mb-8 group">
          <img src="/images/logo.webp" alt="Attack A Crack" class="w-10 h-10 rounded-lg object-cover" width="200" height="200" loading="lazy" />
          <div class="flex flex-col">
            <span class="font-black text-lg tracking-tighter leading-none text-aac-dark">ATTACK A CRACK</span>
            <span class="text-[9px] uppercase tracking-[0.2em] text-aac-blue font-bold mt-1">Foundation Repair</span>
          </div>
        </a>
        <p class="text-zinc-500 text-sm font-bold leading-relaxed mb-8 max-w-sm">
          New England's trusted family-owned foundation repair contractor for over 20 years.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={`tel:${CT_NUMBER}`} class="bg-aac-yellow text-aac-dark px-6 py-3 rounded-xl border-2 border-aac-dark shadow-[4px_4px_0px_0px_rgba(26,26,26,1)] hover:translate-y-[-2px] transition-all text-center flex-1">
            <span class="block text-[9px] font-black uppercase tracking-widest">Connecticut</span>
            <span class="block text-sm font-black">{CT_NUMBER}</span>
          </a>
          <a href={`tel:${MA_NUMBER}`} class="bg-aac-blue text-white px-6 py-3 rounded-xl border-2 border-aac-dark shadow-[4px_4px_0px_0px_rgba(26,26,26,1)] hover:translate-y-[-2px] transition-all text-center flex-1">
            <span class="block text-[9px] font-black uppercase tracking-widest">Massachusetts</span>
            <span class="block text-sm font-black">{MA_NUMBER}</span>
          </a>
        </div>
        <p class="text-[10px] text-zinc-400 font-bold mt-8 tracking-wide">
          Licensed Home Improvement Contractor:
          <a href="https://www.elicense.ct.gov/Lookup/LicenseLookup.aspx" target="_blank" rel="noopener noreferrer" class="hover:text-aac-blue transition-colors">CT #0629164</a> |
          <a href="https://contractorhub.mass.gov/s/hic-contractor-search" target="_blank" rel="noopener noreferrer" class="hover:text-aac-blue transition-colors">MA #214356</a>
        </p>
        <div class="flex items-center gap-4 mt-4">
          <a href="https://www.facebook.com/attackacrack" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-aac-blue transition-colors" aria-label="Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/attackacrack/" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-aac-blue transition-colors" aria-label="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/attack-a-crack" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-aac-blue transition-colors" aria-label="LinkedIn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-8 lg:contents">
      <div class="lg:col-span-3">
        <p class="font-black text-aac-dark uppercase tracking-widest text-xs mb-8">Quick Links</p>
        <ul class="space-y-0">
          <li>
            <a href="/updates" class="text-zinc-500 hover:text-aac-blue font-bold text-sm transition-colors uppercase tracking-widest text-[10px] inline-flex items-center min-h-12">Updates</a>
          </li>
          <li>
            <a href="/partners" class="text-zinc-500 hover:text-aac-blue font-bold text-sm transition-colors uppercase tracking-widest text-[10px] inline-flex items-center min-h-12">Partnerships</a>
          </li>
          <li>
            <a href="/services/wall-crack-repair" class="text-zinc-500 hover:text-aac-blue font-bold text-sm transition-colors uppercase tracking-widest text-[10px] inline-flex items-center min-h-12">Wall Crack Repair</a>
          </li>
          <li>
            <a href="/services/leaky-bulkhead-repair" class="text-zinc-500 hover:text-aac-blue font-bold text-sm transition-colors uppercase tracking-widest text-[10px] inline-flex items-center min-h-12">Leaky Bulkheads</a>
          </li>
          <li>
            <a href="/about" class="text-zinc-500 hover:text-aac-blue font-bold text-sm transition-colors uppercase tracking-widest text-[10px] inline-flex items-center min-h-12">About Our Team</a>
          </li>
          <li>
            <a href="/what-we-dont-do" class="text-zinc-500 hover:text-aac-blue font-bold text-sm transition-colors uppercase tracking-widest text-[10px] inline-flex items-center min-h-12">What We Don't Do</a>
          </li>
        </ul>
      </div>

      <div class="lg:col-span-4">
        <p class="font-black text-aac-dark uppercase tracking-widest text-xs mb-8">Service Areas</p>
        <ul class="space-y-0">
          <li>
            <a href="/connecticut" class="text-zinc-500 hover:text-aac-blue font-bold text-sm transition-colors uppercase tracking-widest text-[10px] flex items-center gap-2 min-h-12">
              <Icon name="MapPin" size={14} class="text-aac-blue shrink-0" /> Connecticut
            </a>
          </li>
          <li>
            <a href="/massachusetts" class="text-zinc-500 hover:text-aac-blue font-bold text-sm transition-colors uppercase tracking-widest text-[10px] flex items-center gap-2 min-h-12">
              <Icon name="MapPin" size={14} class="text-aac-blue shrink-0" /> Massachusetts
            </a>
          </li>
          <li>
            <a href="/rhode-island" class="text-zinc-500 hover:text-aac-blue font-bold text-sm transition-colors uppercase tracking-widest text-[10px] flex items-center gap-2 min-h-12">
              <Icon name="MapPin" size={14} class="text-aac-blue shrink-0" /> Rhode Island
            </a>
          </li>
          <li>
            <a href="/new-hampshire" class="text-zinc-500 hover:text-aac-blue font-bold text-sm transition-colors uppercase tracking-widest text-[10px] flex items-center gap-2 min-h-12">
              <Icon name="MapPin" size={14} class="text-aac-blue shrink-0" /> New Hampshire
            </a>
          </li>
          <li>
            <a href="/maine" class="text-zinc-500 hover:text-aac-blue font-bold text-sm transition-colors uppercase tracking-widest text-[10px] flex items-center gap-2 min-h-12">
              <Icon name="MapPin" size={14} class="text-aac-blue shrink-0" /> Maine
            </a>
          </li>
        </ul>
        <a href="/locations" class="inline-flex items-center gap-2 mt-4 text-aac-blue font-bold text-[10px] uppercase tracking-widest hover:underline min-h-12">
          View All Locations <Icon name="ArrowRight" size={12} />
        </a>
      </div>
      </div>
    </div>

    <div class="pt-12 border-t border-zinc-100 flex flex-col md:flex-row justify-between items-center gap-8">
      <p class="text-zinc-500 text-[10px] font-black uppercase tracking-widest">
        © {new Date().getFullYear()} ATTACK A CRACK. ALL RIGHTS RESERVED.
      </p>
      <div class="flex items-center gap-8">
        <a href="/privacy" class="text-zinc-500 hover:text-aac-blue text-[10px] font-black uppercase tracking-widest transition-colors inline-flex items-center min-h-12">Privacy Policy</a>
        <a href="/terms" class="text-zinc-500 hover:text-aac-blue text-[10px] font-black uppercase tracking-widest transition-colors inline-flex items-center min-h-12">Terms of Service</a>
        <a href={googleReviewsUrlCT} target="_blank" class="text-aac-blue hover:underline text-[10px] font-black uppercase tracking-widest transition-colors flex items-center gap-2 min-h-12">
          CT Google Reviews <Icon name="ExternalLink" size={12} />
        </a>
        <a href={googleReviewsUrlMA} target="_blank" class="text-aac-blue hover:underline text-[10px] font-black uppercase tracking-widest transition-colors flex items-center gap-2 min-h-12">
          MA Google Reviews <Icon name="ExternalLink" size={12} />
        </a>
      </div>
    </div>
  </div>
</footer>
