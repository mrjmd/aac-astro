---
/**
 * ProjectMap — Interactive SVG map of MA with clickable project pins.
 * Groups projects by city. Pins link to city pages (if one exists) or project pages.
 */

interface Project {
  id: string;
  data: {
    title: string;
    city: string;
    state: string;
    coordinates?: { lat: number; lng: number };
  };
}

interface Location {
  id: string;
  data: {
    city: string;
    stateAbbr: string;
  };
}

interface Props {
  projects: Project[];
  locations?: Location[];
}

const { projects, locations = [] } = Astro.props;

// Build a map of city name → location page URL
const cityPageMap = new Map<string, string>();
for (const loc of locations) {
  const slug = loc.id.replace(/\.md$/, '').replace(/^massachusetts\//, '');
  cityPageMap.set(loc.data.city, `/massachusetts/${slug}`);
}

// Group projects by city (using first project's coordinates per city)
const cityGroups = new Map<string, { lat: number; lng: number; count: number; slug: string; city: string }>();
for (const p of projects) {
  if (!p.data.coordinates) continue;
  const key = p.data.city;
  if (!cityGroups.has(key)) {
    cityGroups.set(key, {
      lat: p.data.coordinates.lat,
      lng: p.data.coordinates.lng,
      count: 1,
      slug: p.id.replace(/\.md$/, ''),
      city: p.data.city,
    });
  } else {
    cityGroups.get(key)!.count++;
  }
}

// MA bounding box (with padding)
const bounds = {
  minLat: 41.15,
  maxLat: 42.95,
  minLng: -73.55,
  maxLng: -69.80,
};

const svgWidth = 600;
const svgHeight = 340;
const padX = 20;
const padY = 15;

function toSvg(lat: number, lng: number): { x: number; y: number } {
  const x = padX + ((lng - bounds.minLng) / (bounds.maxLng - bounds.minLng)) * (svgWidth - 2 * padX);
  const y = padY + ((bounds.maxLat - lat) / (bounds.maxLat - bounds.minLat)) * (svgHeight - 2 * padY);
  return { x, y };
}

const pins = Array.from(cityGroups.values()).map(g => ({
  ...toSvg(g.lat, g.lng),
  count: g.count,
  city: g.city,
  slug: g.slug,
  href: cityPageMap.get(g.city) || `/projects/${g.slug}`,
}));

// Simplified MA state outline (approximate polygon points)
const maOutline = [
  { lat: 42.74, lng: -73.26 },
  { lat: 42.74, lng: -72.45 },
  { lat: 42.74, lng: -71.80 },
  { lat: 42.74, lng: -71.33 },
  { lat: 42.87, lng: -71.02 },
  { lat: 42.87, lng: -70.82 },
  { lat: 42.88, lng: -70.82 },
  { lat: 42.80, lng: -70.82 },
  { lat: 42.63, lng: -70.63 },
  { lat: 42.64, lng: -70.60 },
  { lat: 42.59, lng: -70.65 },
  { lat: 42.50, lng: -70.83 },
  { lat: 42.39, lng: -70.96 },
  { lat: 42.33, lng: -70.97 },
  { lat: 42.25, lng: -70.80 },
  { lat: 42.20, lng: -70.72 },
  { lat: 42.10, lng: -70.66 },
  { lat: 42.04, lng: -70.60 },
  { lat: 41.96, lng: -70.58 },
  { lat: 41.88, lng: -70.50 },
  { lat: 42.07, lng: -70.18 },
  { lat: 42.05, lng: -70.06 },
  { lat: 41.92, lng: -69.94 },
  { lat: 41.70, lng: -69.95 },
  { lat: 41.66, lng: -69.96 },
  { lat: 41.63, lng: -70.10 },
  { lat: 41.56, lng: -70.55 },
  { lat: 41.54, lng: -70.61 },
  { lat: 41.55, lng: -70.66 },
  { lat: 41.74, lng: -70.62 },
  { lat: 41.74, lng: -70.68 },
  { lat: 41.74, lng: -70.72 },
  { lat: 41.63, lng: -70.86 },
  { lat: 41.50, lng: -71.02 },
  { lat: 41.48, lng: -71.02 },
  { lat: 41.60, lng: -71.12 },
  { lat: 41.68, lng: -71.12 },
  { lat: 41.78, lng: -71.38 },
  { lat: 42.01, lng: -71.38 },
  { lat: 42.01, lng: -71.80 },
  { lat: 42.04, lng: -72.10 },
  { lat: 42.03, lng: -72.53 },
  { lat: 42.03, lng: -72.78 },
  { lat: 42.04, lng: -73.00 },
  { lat: 42.05, lng: -73.23 },
  { lat: 42.74, lng: -73.26 },
].map(p => toSvg(p.lat, p.lng));

const outlinePath = maOutline.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ') + ' Z';
---

<div class="project-map-container">
  <svg
    viewBox={`0 0 ${svgWidth} ${svgHeight}`}
    class="w-full h-auto"
    role="group"
    aria-label={`Interactive map of ${pins.length} Massachusetts cities where we've completed foundation repair projects`}
  >
    <defs>
      <linearGradient id="state-fill" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#f8fafc" />
        <stop offset="100%" stop-color="#e2e8f0" />
      </linearGradient>
      <filter id="pin-shadow" x="-50%" y="-50%" width="200%" height="200%">
        <feDropShadow dx="0" dy="1" stdDeviation="2" flood-color="#000" flood-opacity="0.2" />
      </filter>
    </defs>

    <!-- State outline -->
    <path
      d={outlinePath}
      fill="url(#state-fill)"
      stroke="#94a3b8"
      stroke-width="2"
    />

    {/* Decorative pulse rings — behind everything */}
    {pins.filter(pin => pin.count > 1).map(pin => (
      <circle
        cx={pin.x}
        cy={pin.y}
        r="10"
        fill="none"
        stroke="#2563eb"
        stroke-width="2"
        class="pulse-ring"
      />
    ))}

    {/* Clickable pin links */}
    {pins.map(pin => {
      const isMulti = pin.count > 1;
      const r = isMulti ? 10 : 8;
      const labelText = `${pin.city}: ${pin.count} featured project${pin.count > 1 ? 's' : ''}`;
      return (
        <a
          href={pin.href}
          class="project-pin"
          aria-label={labelText}
          data-city={pin.city}
        >
          <circle
            cx={pin.x}
            cy={pin.y}
            r={r}
            fill="#2563eb"
            stroke="white"
            stroke-width="2"
            class="pin-dot"
            filter="url(#pin-shadow)"
          />
          {isMulti && (
            <text
              x={pin.x}
              y={pin.y + 1}
              text-anchor="middle"
              dominant-baseline="middle"
              fill="white"
              font-size="10"
              font-weight="bold"
              class="pin-count"
              aria-hidden="true"
            >
              {pin.count}
            </text>
          )}
        </a>
      );
    })}

    {/* Tooltip layer — rendered AFTER all pins so it always paints on top */}
    <g class="tooltip-layer" aria-hidden="true">
      {pins.map(pin => {
        const isMulti = pin.count > 1;
        const r = isMulti ? 10 : 8;
        const textWidth = pin.city.length * 7 + 16;
        return (
          <g class="pin-tooltip" data-tooltip-city={pin.city}>
            <rect
              x={pin.x - textWidth / 2}
              y={pin.y - r - 28}
              width={textWidth}
              height={22}
              rx="4"
              fill="#18181b"
              opacity="0.9"
            />
            <polygon
              points={`${pin.x - 5},${pin.y - r - 6} ${pin.x + 5},${pin.y - r - 6} ${pin.x},${pin.y - r - 1}`}
              fill="#18181b"
              opacity="0.9"
            />
            <text
              x={pin.x}
              y={pin.y - r - 14}
              text-anchor="middle"
              dominant-baseline="middle"
              fill="white"
              font-size="11"
              font-weight="600"
            >
              {pin.city}
            </text>
          </g>
        );
      })}
    </g>
  </svg>

  <!-- Legend -->
  <div class="flex items-center justify-center gap-6 mt-1 text-sm text-zinc-500">
    <div class="flex items-center gap-2">
      <span class="inline-block w-3.5 h-3.5 rounded-full bg-blue-600 border-2 border-white shadow-sm"></span>
      <span>Single project</span>
    </div>
    <div class="flex items-center gap-2">
      <span class="inline-block w-4.5 h-4.5 rounded-full bg-blue-600 border-2 border-white shadow-sm text-white text-[8px] font-bold flex items-center justify-center" style="width:18px;height:18px;font-size:8px;display:inline-flex;align-items:center;justify-content:center;">3</span>
      <span>Multiple projects</span>
    </div>
  </div>
</div>

<style>
  .project-map-container {
    max-width: 100%;
  }

  .project-pin {
    cursor: pointer;
  }

  .project-pin .pin-dot {
    transition: fill 0.15s ease, stroke 0.15s ease;
  }

  .project-pin:hover .pin-dot {
    fill: #1d4ed8;
    stroke: #bfdbfe;
  }

  /* Focus ring for keyboard navigation */
  .project-pin:focus {
    outline: none;
  }

  .project-pin:focus .pin-dot {
    stroke: #93c5fd;
    stroke-width: 3;
  }

  /* Tooltips hidden by default, shown via JS */
  .pin-tooltip {
    opacity: 0;
    transition: opacity 0.15s ease;
    pointer-events: none;
  }

  .pin-tooltip.is-visible {
    opacity: 1;
  }

  /* Pulse rings */
  .pulse-ring {
    pointer-events: none;
    transform-origin: center;
    transform-box: fill-box;
    animation: pulse-expand 2.5s ease-out infinite;
  }

  @keyframes pulse-expand {
    0% {
      transform: scale(1);
      opacity: 0.5;
    }
    100% {
      transform: scale(2.2);
      opacity: 0;
    }
  }

  .pin-count {
    pointer-events: none;
  }
</style>

<script>
  // Show/hide tooltips on hover — tooltips are in a separate layer
  // so they always render on top of all pins.
  document.querySelectorAll('.project-pin').forEach(pin => {
    const city = pin.getAttribute('data-city');
    const tooltip = document.querySelector(`.pin-tooltip[data-tooltip-city="${city}"]`);
    if (!tooltip) return;

    pin.addEventListener('mouseenter', () => tooltip.classList.add('is-visible'));
    pin.addEventListener('mouseleave', () => tooltip.classList.remove('is-visible'));
    pin.addEventListener('focus', () => tooltip.classList.add('is-visible'));
    pin.addEventListener('blur', () => tooltip.classList.remove('is-visible'));
  });
</script>
