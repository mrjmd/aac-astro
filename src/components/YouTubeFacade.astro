---
/**
 * YouTube Facade — shows a thumbnail + play button instead of loading the
 * full YouTube iframe (~1 MB JS/CSS). The real player loads on click.
 *
 * Usage:
 *   <YouTubeFacade videoId="NMgOgA6yGMs" title="Why our method is better" />
 *   <YouTubeFacade videoId="NMgOgA6yGMs" title="..." aspect="9/16" maxHeight="450px" />
 */
interface Props {
  videoId: string;
  title: string;
  /** CSS aspect-ratio value. Default "16/9" */
  aspect?: string;
  /** Optional max-height constraint */
  maxHeight?: string;
  /** Extra CSS classes on the outer wrapper */
  class?: string;
  /** Inline style overrides for the iframe once loaded */
  iframeStyle?: string;
  /** Extra iframe class */
  iframeClass?: string;
}

const {
  videoId,
  title,
  aspect = '16/9',
  maxHeight,
  class: className = '',
  iframeStyle = '',
  iframeClass = '',
} = Astro.props;

const thumbUrl = `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
---

<div
  class:list={['yt-facade group relative cursor-pointer bg-zinc-900 overflow-hidden', className]}
  style={`aspect-ratio: ${aspect};${maxHeight ? ` max-height: ${maxHeight};` : ''}`}
  data-video-id={videoId}
  data-video-title={title}
  data-iframe-style={iframeStyle}
  data-iframe-class={iframeClass}
  role="button"
  tabindex="0"
  aria-label={`Play video: ${title}`}
>
  <img
    src={thumbUrl}
    srcset={`https://i.ytimg.com/vi/${videoId}/hqdefault.jpg 480w, https://i.ytimg.com/vi/${videoId}/sddefault.jpg 640w, https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg 1280w`}
    sizes="(max-width: 640px) 100vw, 640px"
    alt={title}
    class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
    loading="lazy"
    referrerpolicy="no-referrer"
  />
  <!-- Play button overlay -->
  <div class="absolute inset-0 flex items-center justify-center">
    <div class="w-16 h-12 bg-red-600 rounded-xl flex items-center justify-center group-hover:bg-red-500 transition-colors shadow-lg">
      <svg viewBox="0 0 24 24" fill="white" class="w-7 h-7 ml-1">
        <path d="M8 5v14l11-7z" />
      </svg>
    </div>
  </div>
</div>
