---
/**
 * Sticky Mobile CTA Bar
 *
 * Fixed-bottom bar on mobile/tablet with "Call Now" and "Text Photos" buttons.
 * Hidden on desktop (lg:hidden). Appears on scroll past the hero section.
 *
 * Props:
 *   phoneHref - Optional direct tel: link. If provided, "Call Now" dials directly.
 *               If omitted, "Call Now" opens the location modal in call mode.
 *   smsHref - Optional direct SMS link. If provided, "Text Photos" links directly.
 *             If omitted, "Text Photos" opens the location modal in text mode.
 *
 * State pages (CT/MA/RI/NH/ME) get direct phoneHref + smsHref.
 * Generic pages (home, services, blog, about) get neither — both buttons open modals.
 */
import Icon from './Icon.astro';
import { phoneCT, phoneMA } from '../utils/contact';

interface Props {
  phoneHref?: string;
  smsHref?: string;
}

const { phoneHref, smsHref } = Astro.props;
---

<nav
  id="sticky-cta"
  data-sticky-cta
  class="fixed bottom-0 left-0 right-0 z-40 lg:hidden translate-y-full transition-transform duration-300"
  aria-label="Quick contact"
>
  <div class="bg-aac-dark/95 backdrop-blur-sm border-t border-white/10 px-6 py-2.5">
    <div class="flex items-center justify-center gap-3">
      {phoneHref ? (
        <a
          href={phoneHref}
          class="bg-aac-yellow text-aac-dark px-6 py-2 rounded-full font-black uppercase tracking-widest text-[10px] inline-flex items-center gap-2 active:scale-95 transition-transform"
        >
          <Icon name="Phone" size={14} />
          Call Now
        </a>
      ) : (<Fragment>
        <button
          class="open-call-modal geo-modal-trigger bg-aac-yellow text-aac-dark px-6 py-2 rounded-full font-black uppercase tracking-widest text-[10px] inline-flex items-center gap-2 active:scale-95 transition-transform"
        >
          <Icon name="Phone" size={14} />
          Call Now
        </button>
        <a href={`tel:${phoneCT}`} class="geo-direct-action geo-phone-ct bg-aac-yellow text-aac-dark px-6 py-2 rounded-full font-black uppercase tracking-widest text-[10px] items-center gap-2 active:scale-95 transition-transform" style="--geo-display: inline-flex">
          <Icon name="Phone" size={14} />
          Call Now
        </a>
        <a href={`tel:${phoneMA}`} class="geo-direct-action geo-phone-ma bg-aac-yellow text-aac-dark px-6 py-2 rounded-full font-black uppercase tracking-widest text-[10px] items-center gap-2 active:scale-95 transition-transform" style="--geo-display: inline-flex">
          <Icon name="Phone" size={14} />
          Call Now
        </a>
      </Fragment>)}
      {smsHref ? (
        <a
          href={smsHref}
          class="bg-white/10 text-white px-6 py-2 rounded-full font-black uppercase tracking-widest text-[10px] border border-white/20 inline-flex items-center gap-2 active:scale-95 transition-transform"
        >
          <Icon name="MessageSquare" size={14} />
          Text Photos
        </a>
      ) : (<Fragment>
        <button
          class="open-modal geo-modal-trigger bg-white/10 text-white px-6 py-2 rounded-full font-black uppercase tracking-widest text-[10px] border border-white/20 inline-flex items-center gap-2 active:scale-95 transition-transform"
        >
          <Icon name="MessageSquare" size={14} />
          Text Photos
        </button>
        <a href={`sms:${phoneCT}`} class="geo-direct-action geo-phone-ct bg-white/10 text-white px-6 py-2 rounded-full font-black uppercase tracking-widest text-[10px] border border-white/20 items-center gap-2 active:scale-95 transition-transform" style="--geo-display: inline-flex">
          <Icon name="MessageSquare" size={14} />
          Text Photos
        </a>
        <a href={`sms:${phoneMA}`} class="geo-direct-action geo-phone-ma bg-white/10 text-white px-6 py-2 rounded-full font-black uppercase tracking-widest text-[10px] border border-white/20 items-center gap-2 active:scale-95 transition-transform" style="--geo-display: inline-flex">
          <Icon name="MessageSquare" size={14} />
          Text Photos
        </a>
      </Fragment>)}
    </div>
  </div>
</nav>

<style>
  /* No safe area padding — let the buttons sit low in the bevel,
     dark background extends behind them into the curved area */
  .safe-area-pb {
    padding-bottom: 0;
  }
</style>

<script>
  const stickyCta = document.getElementById('sticky-cta');
  const heroSection = document.querySelector('main > section:first-of-type');

  if (stickyCta && heroSection) {
    // Show/hide based on hero visibility
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          stickyCta.classList.add('translate-y-full');
          stickyCta.classList.remove('translate-y-0');
        } else {
          stickyCta.classList.remove('translate-y-full');
          stickyCta.classList.add('translate-y-0');
        }
      },
      { threshold: 0 }
    );
    observer.observe(heroSection);

  }
</script>
