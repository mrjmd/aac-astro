---
import Icon from './Icon.astro';
import YouTubeFacade from './YouTubeFacade.astro';
import { reviewCount } from '../utils/reviews';
---

<section data-hero class="relative min-h-screen flex items-center pt-20 md:pt-32 pb-6 md:pb-20 overflow-hidden bg-white">
  <div class="max-w-7xl mx-auto px-6 w-full grid lg:grid-cols-2 gap-12 items-center relative z-10">
    <div class="text-left [container-type:inline-size]">
      <h1 class="font-display font-black tracking-tighter text-aac-dark leading-[0.85] mb-6 md:mb-8">
        <span class="block sm:hidden text-[10.2vw] whitespace-nowrap">WE SEAL CRACKS &</span>
        <span class="block sm:hidden text-[9.4vw] whitespace-nowrap"><span class="text-aac-blue">SECURE</span> YOUR HOME</span>
        <span class="hidden sm:block">
          <span class="block text-[11.5cqw] whitespace-nowrap">WE SEAL CRACKS &</span>
          <span class="block text-[10.5cqw] whitespace-nowrap"><span class="text-aac-blue">SECURE</span> YOUR HOME</span>
        </span>
      </h1>

      <p class="text-lg font-bold text-zinc-500 max-w-lg mb-6 md:mb-12 leading-relaxed">
        Speak directly with a <span class="text-aac-dark font-black border-b-4 border-aac-yellow">foundation expert</span> right now. We provide durable solutions and quotes within&nbsp;minutes.
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-4 md:gap-8">
        <button
          class="open-modal bg-aac-yellow text-aac-dark px-10 py-6 rounded-2xl font-black text-xl uppercase tracking-widest hover:translate-y-[-4px] transition-all shadow-[8px_8px_0px_0px_rgba(26,26,26,1)] border-4 border-aac-dark flex items-center justify-center gap-3 group"
        >
          <Icon name="MessageSquare" size={24} />
          Text Photos
          <Icon name="ArrowRight" size={24} class="group-hover:translate-x-2 transition-transform" />
        </button>

        <div class="flex flex-col items-center sm:items-start">
          <div class="flex items-center gap-1 mb-1">
            {[...Array(5)].map(() => <Icon name="Star" size={16} class="fill-aac-yellow text-aac-dark" />)}
          </div>
          <p class="text-[10px] font-black uppercase tracking-widest text-zinc-500">{reviewCount}+ Excellent CT Reviews</p>
        </div>
      </div>
    </div>

    <div class="relative">
      <div class="rounded-[48px] overflow-hidden border-8 border-white shadow-[24px_24px_60px_-15px_rgba(0,0,0,0.1)]">
        <YouTubeFacade
          videoId="IXrQmjHXLVg"
          title="Attack A Crack Foundation Repair — Company Overview"
        />
      </div>

      <!-- 15-Minute Quote Badge -->
      <div class="absolute -top-8 -right-8 lg:-rotate-6 w-28 h-28 bg-aac-blue text-white rounded-3xl flex flex-col items-center justify-center text-center border-8 border-white shadow-2xl animate-pulse-soft">
        <span class="text-[9px] font-black uppercase tracking-widest">Quotes in</span>
        <span class="text-3xl font-black leading-none">15</span>
        <span class="text-[9px] font-black uppercase tracking-widest">Minutes</span>
      </div>
    </div>
  </div>
</section>
