---
// 3-step process bar for city pages
---

<section class="py-4 bg-zinc-50 border-b border-zinc-200">
	<div class="max-w-4xl mx-auto px-4 sm:px-6">
		<div class="flex items-center justify-center gap-2 sm:gap-0">
			<!-- Step 1 -->
			<div class="flex items-center gap-1.5 sm:gap-3">
				<div class="w-7 h-7 sm:w-10 sm:h-10 bg-aac-blue text-white rounded-full flex items-center justify-center font-black text-xs sm:text-sm shrink-0">1</div>
				<span class="font-bold text-aac-dark text-xs sm:text-sm">Text Photos</span>
			</div>

			<!-- Arrow -->
			<div class="mx-1.5 sm:mx-4 w-4 sm:w-8 h-0.5 bg-zinc-300"></div>

			<!-- Step 2 -->
			<div class="flex items-center gap-1.5 sm:gap-3">
				<div class="w-7 h-7 sm:w-10 sm:h-10 bg-aac-blue text-white rounded-full flex items-center justify-center font-black text-xs sm:text-sm shrink-0">2</div>
				<span class="font-bold text-aac-dark text-xs sm:text-sm">Get a Quote</span>
			</div>

			<!-- Arrow -->
			<div class="mx-1.5 sm:mx-4 w-4 sm:w-8 h-0.5 bg-zinc-300"></div>

			<!-- Step 3 -->
			<div class="flex items-center gap-1.5 sm:gap-3">
				<div class="w-7 h-7 sm:w-10 sm:h-10 bg-aac-blue text-white rounded-full flex items-center justify-center font-black text-xs sm:text-sm shrink-0">3</div>
				<span class="font-bold text-aac-dark text-xs sm:text-sm">Schedule Repair</span>
			</div>
		</div>
	</div>
</section>
