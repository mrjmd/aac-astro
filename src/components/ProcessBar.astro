---
// 3-step process bar for city pages
---

<section class="py-6 bg-zinc-50 border-b border-zinc-200">
	<div class="max-w-4xl mx-auto px-6">
		<div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-0">
			<!-- Step 1 -->
			<div class="flex items-center gap-3">
				<div class="w-10 h-10 bg-aac-blue text-white rounded-full flex items-center justify-center font-black text-sm shrink-0">1</div>
				<span class="font-bold text-aac-dark text-sm">Text Us Photos</span>
			</div>

			<!-- Arrow -->
			<div class="hidden sm:block mx-4 w-8 h-0.5 bg-zinc-300"></div>
			<div class="sm:hidden h-4 w-0.5 bg-zinc-300"></div>

			<!-- Step 2 -->
			<div class="flex items-center gap-3">
				<div class="w-10 h-10 bg-aac-blue text-white rounded-full flex items-center justify-center font-black text-sm shrink-0">2</div>
				<span class="font-bold text-aac-dark text-sm">Get a Quote</span>
			</div>

			<!-- Arrow -->
			<div class="hidden sm:block mx-4 w-8 h-0.5 bg-zinc-300"></div>
			<div class="sm:hidden h-4 w-0.5 bg-zinc-300"></div>

			<!-- Step 3 -->
			<div class="flex items-center gap-3">
				<div class="w-10 h-10 bg-aac-blue text-white rounded-full flex items-center justify-center font-black text-sm shrink-0">3</div>
				<span class="font-bold text-aac-dark text-sm">Schedule Your Repair</span>
			</div>
		</div>
	</div>
</section>
