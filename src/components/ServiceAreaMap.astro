---
/**
 * ServiceAreaMap — Interactive SVG map of New England with clickable city pins.
 * Each pin links to the city's location page. VT shown as context only.
 * Cape Cod has proper hook shape for geographic accuracy.
 */
import { getCollection } from 'astro:content';

const allLocations = await getCollection('locations');

const stateSlugMap: Record<string, string> = {
  CT: 'connecticut',
  MA: 'massachusetts',
  RI: 'rhode-island',
  NH: 'new-hampshire',
  ME: 'maine',
};

const pins = allLocations
  .filter(loc => loc.data.coordinates)
  .map(loc => {
    const stateSlug = stateSlugMap[loc.data.stateAbbr];
    const citySlug = loc.id.replace(/\.md$/, '').replace(/^[^/]+\//, '');
    return {
      city: loc.data.city,
      state: loc.data.stateAbbr,
      lat: loc.data.coordinates!.lat,
      lng: loc.data.coordinates!.lng,
      href: `/${stateSlug}/${citySlug}`,
    };
  });

// Bounding box: just New England + VT context
const bounds = {
  minLat: 40.90,
  maxLat: 45.20,
  minLng: -73.80,
  maxLng: -66.80,
};

const svgWidth = 600;
const svgHeight = 560;
const padX = 15;
const padY = 15;

function toSvg(lat: number, lng: number): { x: number; y: number } {
  const cosLat = Math.cos((43.5 * Math.PI) / 180); // cos correction at ~center latitude
  const lngRange = (bounds.maxLng - bounds.minLng) * cosLat;
  const latRange = bounds.maxLat - bounds.minLat;
  const aspect = lngRange / latRange;
  const drawW = svgWidth - 2 * padX;
  const drawH = svgHeight - 2 * padY;

  // Fit to width, center vertically (or vice versa)
  let scaleX: number, scaleY: number, offX = 0, offY = 0;
  if (drawW / drawH > aspect) {
    // height-constrained
    scaleY = drawH / latRange;
    scaleX = scaleY * cosLat;
    offX = (drawW - (bounds.maxLng - bounds.minLng) * scaleX) / 2;
  } else {
    scaleX = drawW / ((bounds.maxLng - bounds.minLng) * cosLat) * cosLat;
    scaleY = scaleX / cosLat;
    offY = (drawH - latRange * scaleY) / 2;
  }

  const x = padX + offX + (lng - bounds.minLng) * scaleX;
  const y = padY + offY + (bounds.maxLat - lat) * scaleY;
  return { x, y };
}

const svgPins = pins.map(p => ({
  ...toSvg(p.lat, p.lng),
  city: p.city,
  state: p.state,
  href: p.href,
}));

// Unique color per state
const stateColors: Record<string, { fill: string; pin: string; label: string }> = {
  CT: { fill: '#dbeafe', pin: '#2563eb', label: 'Connecticut' },
  MA: { fill: '#fce7f3', pin: '#db2777', label: 'Massachusetts' },
  RI: { fill: '#ede9fe', pin: '#7c3aed', label: 'Rhode Island' },
