function outlinePath(points: Array<{ lat: number; lng: number }>): string {
  return points.map((p, i) => {
    const { x, y } = toSvg(p.lat, p.lng);
    return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ') + ' Z';
}

// State label positions
const stateLabels = [
  { abbr: 'CT', lat: 41.55, lng: -72.75 },
  { abbr: 'MA', lat: 42.25, lng: -72.00 },
  { abbr: 'RI', lat: 41.60, lng: -71.50 },
  { abbr: 'NH', lat: 43.90, lng: -71.60 },
  { abbr: 'ME', lat: 43.80, lng: -69.80 },
  { abbr: 'VT', lat: 43.60, lng: -72.90 },
].map(s => ({ ...s, ...toSvg(s.lat, s.lng) }));

const contextStates = ['VT'];
const serviceStates = ['CT', 'RI', 'MA', 'NH', 'ME'];
---

<div class="service-area-map-container">
  <svg
    viewBox={`0 0 ${svgWidth} ${svgHeight}`}
    class="w-full h-auto"
    role="group"
    aria-label={`Interactive map of ${svgPins.length} cities across New England where we provide foundation repair services`}
  >
    <defs>
      <filter id="ne-pin-shadow" x="-50%" y="-50%" width="200%" height="200%">
        <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-color="#000" flood-opacity="0.15" />
      </filter>
    </defs>

    {/* Context state (VT) — gray, non-interactive */}
    {contextStates.map(state => stateOutlines[state] && (
      <path
        d={outlinePath(stateOutlines[state])}
        fill={contextFill}
        stroke={contextStroke}
        stroke-width="1"
      />
    ))}

    {/* Service area states — colored fills */}
    {serviceStates.map(state => stateOutlines[state] && (
      <path
        d={outlinePath(stateOutlines[state])}
        fill={stateColors[state].fill}
        stroke="#94a3b8"
        stroke-width="1.5"
        class="state-outline"
        data-state={state}
      />
    ))}

    {/* State abbreviation labels */}
    {stateLabels.map(label => {
      const isContext = contextStates.includes(label.abbr);
      return (
        <text
          x={label.x}
          y={label.y}
          text-anchor="middle"
          dominant-baseline="middle"
          fill={isContext ? '#a1a1aa' : '#64748b'}
          font-size={isContext ? '13' : '12'}
          font-weight={isContext ? '600' : '800'}
          class="state-label"
          aria-hidden="true"
        >
          {label.abbr}
        </text>
      );
    })}

    {/* Clickable city pins */}
    {svgPins.map(pin => (
      <a
        href={pin.href}
        class="city-pin"
        aria-label={`${pin.city}, ${pin.state} — view local foundation repair services`}
        data-city={pin.city}
        data-state={pin.state}
      >
        <circle
          cx={pin.x}
          cy={pin.y}
          r="5"
          fill={stateColors[pin.state].pin}
          stroke="white"
          stroke-width="1.5"
          class="pin-dot"
          filter="url(#ne-pin-shadow)"
        />
      </a>
    ))}

    {/* Tooltip layer */}
    <g class="tooltip-layer" aria-hidden="true">
      {svgPins.map(pin => {
        const textWidth = pin.city.length * 6.5 + 14;
        return (
          <g class="pin-tooltip" data-tooltip-city={pin.city}>
            <rect
              x={pin.x - textWidth / 2}
              y={pin.y - 28}
              width={textWidth}
              height={20}
              rx="4"
              fill="#18181b"
              opacity="0.9"
            />
            <polygon
              points={`${pin.x - 4},${pin.y - 8} ${pin.x + 4},${pin.y - 8} ${pin.x},${pin.y - 4}`}
              fill="#18181b"
              opacity="0.9"
            />
            <text
              x={pin.x}
              y={pin.y - 16}
              text-anchor="middle"
              dominant-baseline="middle"
              fill="white"
              font-size="10"
              font-weight="600"
            >
              {pin.city}
            </text>
          </g>
        );
      })}
    </g>
  </svg>

  <!-- Legend -->
  <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 mt-2 text-xs text-zinc-500">
    {serviceStates.map(state => (
      <div class="flex items-center gap-1.5">
        <span class="inline-block w-3 h-3 rounded-full border-2 border-white shadow-sm" style={`background-color: ${stateColors[state].pin}`}></span>
        <span>{stateColors[state].label}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .service-area-map-container {
    max-width: 100%;
  }

  .city-pin {
    cursor: pointer;
  }

  .city-pin .pin-dot {
    transition: fill 0.15s ease, r 0.15s ease;
  }

  .city-pin:hover .pin-dot {
    stroke: #bfdbfe;
    stroke-width: 2.5;
  }

  .city-pin:focus {
    outline: none;
  }

  .city-pin:focus .pin-dot {
    stroke: #93c5fd;
    stroke-width: 3;
  }

  .pin-tooltip {
    opacity: 0;
    transition: opacity 0.15s ease;
    pointer-events: none;
  }

  .pin-tooltip.is-visible {
    opacity: 1;
  }

  .state-label {
    pointer-events: none;
    user-select: none;
  }
</style>

<script>
  document.querySelectorAll('.city-pin').forEach(pin => {
    const city = pin.getAttribute('data-city');
    const tooltip = document.querySelector(`.pin-tooltip[data-tooltip-city="${city}"]`);
    if (!tooltip) return;

    pin.addEventListener('mouseenter', () => tooltip.classList.add('is-visible'));
    pin.addEventListener('mouseleave', () => tooltip.classList.remove('is-visible'));
    pin.addEventListener('focus', () => tooltip.classList.add('is-visible'));
    pin.addEventListener('blur', () => tooltip.classList.remove('is-visible'));
  });
</script>
